---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'PointBreakLab — Privacy-First Applications',
  description = 'PointBreakLab builds privacy-first applications for a world that is watching. No servers. No surveillance. No compromise.',
  ogImage = '/og-image.png',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- OG / Twitter -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="PointBreakLab" />
    <meta name="twitter:card"       content="summary_large_image" />
    <meta name="twitter:title"      content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"      content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-primary font-sans antialiased overflow-x-hidden">
    <slot />
    <script>
      // Intersection Observer for scroll reveal
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.section-reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
