---
export interface Props {
  platform: 'android' | 'ios';
  href: string;
  label?: string;
}
const { platform, href, label } = Astro.props;
const isAndroid = platform === 'android';
---
<a
  href={href}
  class="flex items-center gap-3 px-6 py-4 rounded-2xl bg-surface border border-border hover:border-accent/40 hover:bg-accent/5 transition-all group"
>
  {isAndroid ? (
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" class="text-accent">
      <path d="M6 20C6 21.1 6.9 22 8 22h1v4.5C9 27.3 9.7 28 10.5 28S12 27.3 12 26.5V22h4v4.5c0 .8.7 1.5 1.5 1.5s1.5-.7 1.5-1.5V22h1c1.1 0 2-.9 2-2V10H6v10zm-2.5-10C2.7 10 2 10.7 2 11.5v5c0 .8.7 1.5 1.5 1.5S5 17.3 5 16.5v-5C5 10.7 4.3 10 3.5 10zm21 0c-.8 0-1.5.7-1.5 1.5v5c0 .8.7 1.5 1.5 1.5s1.5-.7 1.5-1.5v-5c0-.8-.7-1.5-1.5-1.5zM18.9 2.3l1.4-1.4c.3-.3.3-.7 0-1s-.7-.3-1 0L17.7 1.5C16.6 1 15.4.7 14 .7S11.4 1 10.3 1.5L8.7-.1c-.3-.3-.7-.3-1 0s-.3.7 0 1l1.4 1.4C7.4 3.6 6 6 6 8.7h16c0-2.7-1.4-5.1-3.1-6.4zM11 6H9.5V4.5H11V6zm7.5 0H17V4.5h1.5V6z" fill="currentColor"/>
    </svg>
  ) : (
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" class="text-primary">
      <path d="M20.5 14.8c0-3.1 2.5-4.6 2.6-4.7-1.4-2.1-3.6-2.4-4.4-2.4-1.9-.2-3.6 1.1-4.6 1.1-.9 0-2.4-1.1-4-1.1-2 0-3.9 1.2-4.9 3-2.1 3.6-.5 9 1.5 12 1 1.4 2.2 3 3.7 3 1.5-.1 2-.9 3.8-.9 1.7 0 2.2.9 3.8.9 1.6 0 2.7-1.5 3.7-2.9.7-1 1.3-2.1 1.7-3.3-4.4-1.7-5.9-5.7-5.9-5.7zM17.6 5.2C18.4 4.2 19 2.8 18.9 1.4c-1.3.1-2.8.9-3.7 1.9-.8.9-1.5 2.3-1.4 3.7 1.5.1 2.9-.7 3.8-1.8z" fill="currentColor"/>
    </svg>
  )}
  <div class="text-left">
    <div class="text-xs text-secondary">
      {isAndroid ? 'Download for' : 'Available on'}
    </div>
    <div class="text-sm font-bold text-primary group-hover:text-accent transition-colors">
      {label ?? (isAndroid ? 'Android APK' : 'iOS')}
    </div>
  </div>
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="ml-auto text-hint group-hover:text-accent transition-colors group-hover:translate-x-0.5">
    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</a>
