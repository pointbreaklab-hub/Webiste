---
---
<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-7 h-7 rounded-md bg-accent flex items-center justify-center">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 1L13 4V10L7 13L1 10V4L7 1Z" stroke="black" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M7 4L10 5.5V8.5L7 10L4 8.5V5.5L7 4Z" fill="black"/>
        </svg>
      </div>
      <span class="font-bold text-sm tracking-wide text-primary group-hover:text-accent transition-colors">
        PointBreak<span class="text-accent">Lab</span>
      </span>
    </a>

    <!-- Desktop links — full paths so they work from any page (homepage,
         /whispr/, /heart/, /privacy/). Per-product changelogs live under
         each app's subtree (/whispr/changelog/, /heart/changelog/) so
         the global Nav doesn't need a top-level Changelog entry. -->
    <ul class="hidden md:flex items-center gap-8 text-sm text-secondary">
      <li><a href="/#apps"               class="hover:text-primary transition-colors">Apps</a></li>
      <li><a href="/whispr/"             class="hover:text-primary transition-colors">Whispr</a></li>
      <li><a href="/heart/"              class="hover:text-primary transition-colors">Heart</a></li>
      <li><a href="/#about"              class="hover:text-primary transition-colors">About</a></li>
    </ul>

    <!-- CTA -->
    <a
      href="/whispr/#download"
      class="hidden md:flex items-center gap-2 px-4 py-2 rounded-lg bg-accent text-bg text-sm font-semibold hover:bg-white transition-colors"
    >
      Download
    </a>

    <!-- Mobile hamburger -->
    <button id="menu-btn" class="md:hidden text-secondary hover:text-primary transition-colors" aria-label="Menu">
      <svg id="icon-open"  width="22" height="22" viewBox="0 0 22 22" fill="none">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 22 22" fill="none" class="hidden">
        <path d="M5 5l12 12M17 5L5 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden md:hidden bg-surface border-t border-border">
    <ul class="flex flex-col px-6 py-4 gap-4 text-sm text-secondary">
      <li><a href="/#apps"               class="block hover:text-primary transition-colors">Apps</a></li>
      <li><a href="/whispr/"             class="block hover:text-primary transition-colors">Whispr</a></li>
      <li><a href="/heart/"              class="block hover:text-primary transition-colors">Heart</a></li>
      <li><a href="/#about"              class="block hover:text-primary transition-colors">About</a></li>
      <li><a href="/whispr/#download"    class="block text-accent font-semibold">Download</a></li>
    </ul>
  </div>
</nav>

<script>
  // Scroll background — passive listener, only updates class when state actually changes.
  // Uses solid bg instead of backdrop-blur (backdrop-filter is the #1 cause of scroll jank on macOS).
  const nav = document.getElementById('nav')!;
  let scrolled = false;
  window.addEventListener('scroll', () => {
    const next = window.scrollY > 40;
    if (next !== scrolled) {
      scrolled = next;
      nav.classList.toggle('nav-scrolled', next);
    }
  }, { passive: true });

  // Mobile menu
  const btn   = document.getElementById('menu-btn')!;
  const menu  = document.getElementById('mobile-menu')!;
  const open  = document.getElementById('icon-open')!;
  const close = document.getElementById('icon-close')!;
  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    open.classList.toggle('hidden', !isOpen);
    close.classList.toggle('hidden', isOpen);
  });
  menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
    menu.classList.add('hidden');
    open.classList.remove('hidden');
    close.classList.add('hidden');
  }));
</script>

<style>
  /* Solid background instead of backdrop-blur — backdrop-filter is GPU-expensive
     and the #1 cause of scroll stutter on macOS / MBP. */
  #nav.nav-scrolled {
    background-color: rgba(10, 10, 10, 0.92);
    border-bottom: 1px solid rgb(38, 38, 38);
  }
</style>
