---
// Editorial chapter-style eyebrow: numbered prefix, hairline divider,
// label, optional trailing dot. Single component used across all
// homepage sections so the visual rhythm is consistent.
//
// Usage:
//   <SectionEyebrow num="02" label="WHISPR" align="center" />
export interface Props {
  num:    string;
  label:  string;
  align?: 'left' | 'center';
}
const { num, label, align = 'center' } = Astro.props;
const justify = align === 'center' ? 'justify-center' : 'justify-start';
---

<div class={`flex items-center gap-3 ${justify} mb-3 text-xs font-mono tracking-widest text-accent`}>
  <span class="opacity-60 tabular-nums">{num}</span>
  <span class="h-px w-8 bg-accent/40"></span>
  <span>{label}</span>
  <span class="h-px w-8 bg-accent/40"></span>
  <span class="w-1 h-1 rounded-full bg-accent/70"></span>
</div>
