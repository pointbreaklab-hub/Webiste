---
export interface Props {
  icon: string;
  title: string;
  description: string;
}
const { icon, title, description } = Astro.props;
---
<div class="section-reveal flex flex-col gap-4 p-6 rounded-2xl bg-surface border border-border hover:border-accent/30 transition-colors group">
  <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-lg group-hover:bg-accent/20 transition-colors">
    {icon}
  </div>
  <h3 class="text-base font-bold text-primary">{title}</h3>
  <p class="text-secondary text-sm leading-relaxed">{description}</p>
</div>
