---
---
<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-bg">

  <!-- Three.js canvas (desktop) -->
  <canvas id="hero-canvas" class="absolute inset-0 w-full h-full hidden md:block opacity-70"></canvas>

  <!-- Static gradient fallback (mobile) -->
  <div class="absolute inset-0 md:hidden">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full bg-accent opacity-5 blur-3xl"></div>
    <div class="absolute bottom-1/3 right-1/4 w-64 h-64 rounded-full bg-blue-500 opacity-5 blur-3xl"></div>
  </div>

  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(0,212,170,1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,212,170,1) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/30 bg-accent/5 text-accent text-xs font-mono tracking-wider mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
      PRIVACY-FIRST · NO SERVERS · NO METADATA
    </div>

    <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-none mb-6">
      <span class="text-primary">PointBreak</span><br/>
      <span class="text-gradient">Lab</span>
    </h1>

    <p class="text-lg md:text-xl text-secondary font-light max-w-xl mx-auto leading-relaxed mb-10">
      Privacy-first applications built for a world that is watching.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#whispr"
        class="px-8 py-3.5 rounded-xl bg-accent text-bg font-bold text-sm hover:bg-white transition-all hover:scale-105 hover:shadow-[0_0_32px_rgba(0,212,170,0.4)]"
      >
        Explore Whispr
      </a>
      <a
        href="#apps"
        class="px-8 py-3.5 rounded-xl border border-border text-secondary text-sm hover:border-accent hover:text-primary transition-all"
      >
        View All Apps
      </a>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-hint text-xs">
      <span>scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-hint to-transparent"></div>
    </div>
  </div>
</section>

<script>
  // Lazy-load Three.js hero animation only on desktop
  if (window.matchMedia('(min-width: 768px)').matches) {
    import('../scripts/hero-three.js').then(({ initHero }) => initHero());
  }
</script>
