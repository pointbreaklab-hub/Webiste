---
// CSS-only animated network. Generated at build time, no JS shipped.
// Replaces an earlier Three.js implementation that cost 468 KB and ran a
// continuous WebGL render loop. See website/CLAUDE.md → "Hero animation".

// Deterministic PRNG so the layout is stable across rebuilds (mulberry32).
function rng(seed: number) {
  let s = seed | 0;
  return () => {
    s = (s + 0x6D2B79F5) | 0;
    let t = Math.imul(s ^ (s >>> 15), 1 | s);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const NODE_COUNT  = 42;
const CONNECT_DIST = 18;       // % of viewBox
const VB_W = 100, VB_H = 60;   // SVG viewBox
const random = rng(424242);

// Place nodes pseudo-randomly, biased away from the dead center where the
// hero text lives so the network frames the headline rather than overlaps it.
const nodes = Array.from({ length: NODE_COUNT }, (_, i) => {
  let x = random() * VB_W;
  let y = random() * VB_H;
  // Push points out of the central headline band (roughly 15-85 width, 22-38 height)
  if (x > 25 && x < 75 && y > 22 && y < 38) {
    if (random() > 0.5) y = y < 30 ? y - 12 : y + 12;
    else                x = x < 50 ? x - 18 : x + 18;
  }
  return {
    i,
    x: Math.max(0, Math.min(VB_W, x)),
    y: Math.max(0, Math.min(VB_H, y)),
    delay: (random() * 8).toFixed(2),  // 0-8s pulse delay
    pulse: random() > 0.78,            // ~22% of nodes get the active pulse
  };
});

// Connect nodes whose Euclidean distance is below the threshold.
const edges: Array<{ x1: number; y1: number; x2: number; y2: number }> = [];
for (let i = 0; i < nodes.length; i++) {
  for (let j = i + 1; j < nodes.length; j++) {
    const dx = nodes[i].x - nodes[j].x;
    const dy = nodes[i].y - nodes[j].y;
    if (Math.hypot(dx, dy) < CONNECT_DIST) {
      edges.push({ x1: nodes[i].x, y1: nodes[i].y, x2: nodes[j].x, y2: nodes[j].y });
    }
  }
}
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-bg">

  <!-- Animated network — pure SVG + CSS, no JS. Hidden behind reduced-motion -->
  <div class="hero-network absolute inset-0 hidden md:block">
    <svg
      class="w-full h-full"
      viewBox={`0 0 ${VB_W} ${VB_H}`}
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      <g class="hero-edges">
        {edges.map(({ x1, y1, x2, y2 }) => (
          <line x1={x1} y1={y1} x2={x2} y2={y2} />
        ))}
      </g>
      <g class="hero-nodes">
        {nodes.map((n) => (
          <circle
            cx={n.x}
            cy={n.y}
            r={n.pulse ? 0.6 : 0.4}
            class={n.pulse ? 'pulse' : ''}
            style={`animation-delay: ${n.delay}s;`}
          />
        ))}
      </g>
    </svg>
  </div>

  <!-- Soft accent orbs — gives depth on every screen size. -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full bg-accent opacity-[0.06] blur-3xl"></div>
    <div class="absolute bottom-1/3 right-1/4 w-64 h-64 rounded-full bg-blue-500 opacity-[0.05] blur-3xl"></div>
  </div>

  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(rgba(0,212,170,1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,212,170,1) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/30 bg-accent/5 text-accent text-xs font-mono tracking-wider mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
      PRIVACY-FIRST · NO SERVERS · NO METADATA
    </div>

    <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[1.05] mb-6">
      <span class="text-primary">Apps that don't</span><br/>
      <span class="text-gradient">watch back.</span>
    </h1>

    <p class="text-lg md:text-xl text-secondary font-light max-w-xl mx-auto leading-relaxed mb-3">
      PointBreakLab builds privacy-first software for the small things that matter — messaging, notes, secrets.
    </p>
    <p class="text-sm text-hint font-mono mb-10">
      Free · encrypted · never on a server.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/whispr/"
        class="px-8 py-3.5 rounded-xl bg-accent text-bg font-bold text-sm hover:bg-white transition-all hover:scale-105 hover:shadow-[0_0_32px_rgba(0,212,170,0.4)]"
      >
        Explore Whispr
      </a>
      <a
        href="#apps"
        class="px-8 py-3.5 rounded-xl border border-border text-secondary text-sm hover:border-accent hover:text-primary transition-all"
      >
        View All Apps
      </a>
    </div>
  </div>

  <!-- Scroll hint — anchored to the section, not the content. Hidden on
       narrow viewports because there's not enough vertical room and it
       overlaps the CTA buttons when the headline wraps. -->
  <div class="hidden md:flex absolute bottom-10 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-hint text-xs pointer-events-none">
    <span>scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-hint to-transparent"></div>
  </div>
</section>

<style>
  /* Network — soft, slow, GPU-friendly. No animation while reduced-motion is on. */
  .hero-network svg {
    opacity: 0.55;
  }
  .hero-edges line {
    stroke: #00d4aa;
    stroke-width: 0.06;
    stroke-linecap: round;
    opacity: 0.18;
  }
  .hero-nodes circle {
    fill: #00d4aa;
    opacity: 0.7;
  }
  .hero-nodes circle.pulse {
    animation: nodePulse 6s ease-in-out infinite;
    transform-origin: center;
    filter: drop-shadow(0 0 0.4px rgba(0, 212, 170, 0.7));
  }
  @keyframes nodePulse {
    0%, 100% { opacity: 0.55; r: 0.45; }
    50%      { opacity: 1;    r: 0.75; }
  }

  /* Whole-network gentle drift — single transform on the SVG, very cheap */
  .hero-network {
    animation: networkDrift 24s ease-in-out infinite alternate;
  }
  @keyframes networkDrift {
    from { transform: translate3d(-0.5%, 0.3%, 0) scale(1); }
    to   { transform: translate3d(0.5%, -0.3%, 0) scale(1.02); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-network,
    .hero-nodes circle.pulse {
      animation: none !important;
    }
  }
</style>
