---
import Base                    from '../../layouts/Base.astro';
import Nav                     from '../../components/Nav.astro';
import FeatureBlock            from '../../components/FeatureBlock.astro';
import Footer                  from '../../components/Footer.astro';
import SectionEyebrow          from '../../components/SectionEyebrow.astro';
import KnotArchitectureDiagram from '../../components/KnotArchitectureDiagram.astro';
import KnotMeshDiagram         from '../../components/KnotMeshDiagram.astro';
import '../../styles/global.css';

// Desktop-app screenshots for the showcase carousel (see "THE DESKTOP APP"
// section below). Mirrors Heart's phone-mockup gallery, but framed in a desktop
// window because Knot is a desktop app, not mobile.
const screenshots = [
  { src: '/screenshots/knot/dashboard.png', caption: 'Dashboard, lifetime commits, devices, storage, bridge health',  alt: 'Knot desktop dashboard with a total-commits counter and device, storage and bridge-health panels' },
  { src: '/screenshots/knot/timeline.png',  caption: 'My Folders, per-project commit history & activity heatmap',     alt: 'Knot project view showing a commit activity heatmap and full commit history timeline' },
  { src: '/screenshots/knot/graph.png',     caption: 'Code graph, see how any codebase fits together',                alt: 'Knot code dependency graph showing modules as nodes radiating from a central node' },
  { src: '/screenshots/knot/activity.png',  caption: 'Activity, watch your AI agents coordinate across machines',      alt: 'Knot activity feed showing AI agents asking and answering across devices' },
  { src: '/screenshots/knot/chat.png',      caption: 'Built-in chat, message your paired devices directly',           alt: 'Knot chat tab showing a conversation between paired devices' },
  { src: '/screenshots/knot/settings.png',  caption: 'Settings, themes, on-device AI, go-dark, auto-save timing',      alt: 'Knot settings panel with theme, language, offline AI and notification options' },
];
---

<Base
  title="Knot · Peer-to-peer version control for the AI era"
  description="Take any folder on your machine. Every save becomes a real git commit and reaches your teammates within seconds, no account, no central server, no four-step push ritual. Peer-to-peer over Tor: no ports to open, no server to run."
>
  <Nav />

  <!-- ── HERO (Knot-specific, slim) ──────────────────────────────────────── -->
  <section class="relative pt-32 pb-20 px-6 overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-[28rem] bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div aria-hidden="true" class="absolute top-1/3 right-0 w-72 h-72 bg-blue-500/[0.04] blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/30 bg-accent/5 text-accent text-xs font-mono tracking-wider mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        KNOT · PEER-TO-PEER VERSION CONTROL
      </div>

      <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6">
        <span class="text-primary">Your code.</span><br/>
        <span class="text-gradient">Your machines.</span><br/>
        <span class="text-primary">No middleman.</span>
      </h1>

      <p class="text-lg text-secondary font-light max-w-xl mx-auto leading-relaxed mb-4">
        Knot watches the folders you choose. Every save becomes a real git commit on your teammates' machines within seconds. No server, no account.
      </p>
      <p class="text-sm text-accent font-mono mb-10 max-w-xl mx-auto leading-relaxed">
        Two machines, two AI agents, one repo: they build it together over your LAN, hands-free, while you watch.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#download"
          class="px-8 py-3.5 rounded-xl bg-accent text-bg font-bold text-sm hover:bg-white transition-all hover:scale-105 hover:shadow-[0_0_32px_rgba(0,212,170,0.4)]"
        >
          Download for Mac / Linux
        </a>
        <a
          href="#architecture"
          class="px-8 py-3.5 rounded-xl border border-border text-secondary text-sm hover:border-accent hover:text-primary transition-all"
        >
          See the architecture
        </a>
      </div>

    </div>
  </section>

  <!-- ── THE DESKTOP APP (UI showcase, desktop-window carousel) ───────────── -->
  <!-- Mirrors Heart's phone-mockup gallery, but in a desktop window frame
       because Knot is a desktop app. Intentionally un-numbered so it doesn't
       renumber the 01–08 chapter sequence below. -->
  <section id="screens" class="relative pb-24 px-6 overflow-hidden">
    <div aria-hidden="true" class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[70%] h-72 bg-accent/[0.06] blur-3xl pointer-events-none"></div>

    <div class="relative max-w-5xl mx-auto">
      <div class="section-reveal text-center mb-10">
        <p class="text-accent text-xs font-mono tracking-widest mb-3">THE DESKTOP APP</p>
        <h2 class="text-2xl md:text-4xl font-light text-primary tracking-tight mb-3">Everything in one window.</h2>
        <p class="text-secondary text-sm max-w-xl mx-auto leading-relaxed">
          A live dashboard, built-in chat, AI-agent activity across your machines, and on-device settings, running natively on Linux and macOS.
        </p>
      </div>

      <div id="knot-carousel" class="section-reveal flex flex-col items-center select-none">
        <!-- desktop window frame -->
        <div class="w-full rounded-xl border border-border bg-[#0e0e11] overflow-hidden"
             style="box-shadow:0 32px 80px rgba(0,0,0,0.6),0 0 0 1px rgba(255,255,255,0.025)">
          <!-- window chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-surface">
            <span class="w-3 h-3 rounded-full bg-error/70"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-accent/70"></span>
            <span class="ml-3 text-xs font-mono text-hint">Knot, peer-to-peer version control</span>
          </div>
          <!-- screen -->
          <div class="relative" style="aspect-ratio:16/10">
            {screenshots.map((s, i) => (
              <img
                src={s.src}
                alt={s.alt}
                loading={i === 0 ? 'eager' : 'lazy'}
                class="absolute inset-0 w-full h-full object-cover object-top"
                style={`opacity:${i === 0 ? 1 : 0};z-index:${i === 0 ? 1 : 0};transition:opacity 0.45s ease`}
                data-knot-slide={i}
              />
            ))}
          </div>
        </div>

        <!-- caption -->
        <div class="relative mt-6 w-full" style="height:32px">
          {screenshots.map((s, i) => (
            <p
              class="absolute inset-0 flex items-center justify-center text-xs font-mono text-hint text-center px-4"
              style={`opacity:${i === 0 ? 1 : 0};transition:opacity 0.35s ease`}
              data-knot-caption={i}
            >
              {s.caption}
            </p>
          ))}
        </div>

        <!-- dots -->
        <div class="flex gap-3 mt-4">
          {screenshots.map((_, i) => (
            <button
              aria-label={`Screen ${i + 1} of ${screenshots.length}`}
              data-knot-dot={i}
              style={i === 0
                ? 'width:8px;height:8px;border-radius:50%;background:#00d4aa;transform:scale(1.3);transition:all 0.3s ease;border:none;cursor:pointer;padding:0'
                : 'width:8px;height:8px;border-radius:50%;background:#737373;transform:scale(1);transition:all 0.3s ease;border:none;cursor:pointer;padding:0'}
            />
          ))}
        </div>
      </div>
    </div>

    <script is:inline>
    (function () {
      var slides   = document.querySelectorAll('[data-knot-slide]');
      var captions = document.querySelectorAll('[data-knot-caption]');
      var dots     = document.querySelectorAll('[data-knot-dot]');
      if (!slides.length) return;
      var n = slides.length, cur = 0, timer = null;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      function show(i) {
        [slides, captions].forEach(function (col) {
          col[cur].style.opacity = '0'; col[cur].style.zIndex = '0';
          col[i].style.opacity   = '1'; col[i].style.zIndex   = '1';
        });
        dots[cur].style.background = '#737373'; dots[cur].style.transform = 'scale(1)';
        dots[i].style.background   = '#00d4aa'; dots[i].style.transform   = 'scale(1.3)';
        cur = i;
      }
      function advance() { show((cur + 1) % n); }
      function start() { if (reduced || timer) return; timer = setInterval(advance, 4500); }
      function stop()  { clearInterval(timer); timer = null; }
      dots.forEach(function (dot, i) { dot.addEventListener('click', function () { stop(); show(i); start(); }); });
      var c = document.getElementById('knot-carousel');
      c.addEventListener('mouseenter', stop);
      c.addEventListener('mouseleave', start);
      start();
    })();
    </script>
  </section>

  <!-- ── 01 HOW IT WORKS ──────────────────────────────────────────────────── -->
  <!-- THE PROBLEM and STORYBOARD sections were removed 2026-07-20 by owner
       decision: the page was over-long and over-claimed. The page's job now:
       what it is (hero) → how it works → what it does → receipts → get it. -->
  <section id="how" class="relative py-28 px-6 bg-surface border-y border-border overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-72 bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="section-reveal text-center mb-16">
        <SectionEyebrow num="01" label="HOW IT WORKS" />
        <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Three pieces. You only see one.</h2>
        <p class="text-secondary max-w-xl mx-auto leading-relaxed">
          The folder and the peers are one-time setup. The save is the only piece in your day; a background helper and the encrypted Tor connection do the rest, invisibly.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            step: '01',
            title: 'The folder',
            body: 'Pick any folder on your machine. Tell Knot once. It now behaves like a git repository, because under the hood it is one. Existing `git` commands still work.',
          },
          {
            step: '02',
            title: 'The peers',
            body: 'Anyone you want to collaborate with installs Knot. You give them a one-time pairing code; they accept it. From that moment, your two machines are paired.',
          },
          {
            step: '03',
            title: 'The save',
            body: 'Open the file. Write code. Hit save. Knot notices the change, waits a moment for you to finish, makes a real git commit, and sends it to every paired teammate. They see it within seconds.',
          },
        ].map(({ step, title, body }) => (
          <div class="section-reveal relative pl-8 border-l border-border hover:border-accent/40 transition-colors">
            <span class="absolute -left-px top-0 w-0.5 h-8 bg-accent"></span>
            <p class="text-accent font-mono text-xs mb-2">{step}</p>
            <h4 class="text-lg font-bold text-primary mb-2">{title}</h4>
            <p class="text-secondary text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>

      <p class="text-center text-hint text-xs mt-12 max-w-xl mx-auto leading-relaxed">
        Same wire-format efficiency as `git fetch` (real pack files). Same content-addressing guarantees (SHA-256 hash chain). What changes is who owns the bytes in transit, only you and your peers.
      </p>
    </div>
  </section>

  <!-- ── 02 FEATURES ──────────────────────────────────────────────────────── -->
  <section id="features" class="relative py-28 px-6 max-w-7xl mx-auto">
    <div aria-hidden="true" class="absolute top-0 right-0 w-[40%] h-72 bg-accent/[0.06] blur-3xl pointer-events-none"></div>

    <div class="section-reveal text-center mb-16">
      <SectionEyebrow num="02" label="FEATURES" />
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">What it does</h2>
      <p class="text-secondary max-w-xl mx-auto leading-relaxed">
        Everything below is built and verified end-to-end on real hardware across networks.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <FeatureBlock
        icon="🤝"
        title="AI agents build together"
        description="AI assistants on your paired machines build one project between them, no human in the loop, and you watch every step live. The thing a central host can't do."
      />
      <FeatureBlock
        icon="💾"
        title="Saves are commits"
        description="Knot turns every save into a real git commit a moment after you stop typing."
      />
      <FeatureBlock
        icon="📡"
        title="Reaches peers across networks"
        description="Commits travel to every teammate over Tor, encrypted end-to-end, on home Wi-Fi or a mobile hotspot. No ports to open."
      />
      <FeatureBlock
        icon="🪪"
        title="Pairing codes, not accounts"
        description="One code carries everything the other device needs. Paste it or scan the QR. Zero accounts, zero email."
      />
      <FeatureBlock
        icon="🪢"
        title="Real git underneath"
        description="Knot uses git's real object format, so `git log`, `git diff`, and `git branch` all still work underneath, nothing to relearn."
      />
      <FeatureBlock
        icon="🧾"
        title="Provable, governed AI"
        description="Every commit is signed by the person and the AI session behind it, and each agent is scoped to the paths it may touch. Out-of-scope changes never commit; export a tamper-evident record anyone can verify."
      />
      <FeatureBlock
        icon="📱"
        title="Follow it from your phone"
        description="A companion mobile app streams every synced repo read-only over your LAN, and notifies you when a commit lands or an agent finishes a task. Keep an eye on the work without opening a laptop."
      />
    </div>
  </section>

  <!-- ── 03 ARCHITECTURE ──────────────────────────────────────────────────── -->
  <section id="architecture" class="relative py-32 px-6 bg-surface border-y border-border overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-72 bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="section-reveal text-center mb-12">
        <SectionEyebrow num="03" label="ARCHITECTURE" />
        <h2 class="text-3xl md:text-5xl font-light text-primary mb-4 tracking-tight">Receipts, not claims.</h2>
        <p class="text-secondary max-w-xl mx-auto">
          The cryptographic and transport primitives Knot ships are open and inspectable. Built in Rust, self-contained builds, no central server to run.
        </p>
      </div>

      <!-- ── Visual end-to-end diagram ──────────────────────────────────────
           The conceptual map of "save → commit → propagate" for readers
           who don't read terminal panels. The technical reference below
           is the same content in primitive-by-primitive form. Both are
           load-bearing, don't drop either. (Pattern mirrored from the
           Whispr product page.) -->
      <div class="section-reveal mb-12">
        <KnotArchitectureDiagram />
      </div>

      <div class="section-reveal mb-12">
        <p class="text-secondary text-center text-sm mb-1">That is two machines. Here is the same loop across a whole team:</p>
        <KnotMeshDiagram />
      </div>

      <div class="section-reveal font-mono text-sm rounded-2xl bg-bg border border-border overflow-hidden">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
          <div class="w-3 h-3 rounded-full bg-error/70"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-accent/70"></div>
          <span class="ml-2 text-hint text-xs">knot-architecture.txt</span>
        </div>
        <div class="p-6 space-y-2.5 text-xs md:text-sm leading-relaxed overflow-x-auto">
          {[
            ['Identity',        'Ed25519 keypair · generated on-device · stored at OS-permission 0600'],
            ['Pairing',         'Mutual `knot1:<base64>` blob exchange · explicit confirm on both sides'],
            ['Wire auth',       'Ed25519 challenge–response · per-connection nonces · no replay'],
            ['Transport',       'Tor · onion-v3 hidden services · no clearnet bytes'],
            ['Object format',   'Real git pack files · libgit2 · `git` CLI works on a Knot folder'],
            ['Push',            'Bundle over Tor · fast-forward only · non-FF lands in refs/knot-incoming/'],
            ['Capabilities',    'Ed25519-signed grants · offline-verifiable · instant revocation'],
            ['Coordinator',     'Optional · sees encrypted bytes only · cannot tamper with the hash chain'],
            ['Server',          'None'],
          ].map(([key, val]) => (
            <div class="flex gap-4 items-baseline">
              <span class="text-hint shrink-0 w-32">{key}</span>
              <span class="text-accent">→</span>
              <span class="text-primary/80">{val}</span>
            </div>
          ))}
        </div>
      </div>

      <p class="text-hint text-xs text-center mt-6 max-w-xl mx-auto leading-relaxed">
        Same Tor primitives that route Whispr's messages. Same git object format that powers every git host on the internet. We didn't reinvent the cryptography; we removed the centralised server.
      </p>
    </div>
  </section>

  <!-- ── 04 PROOF ─────────────────────────────────────────────────────────── -->
  <!-- Token-efficiency benchmark. Honest framing per the corrected
       evidence doc: the A/B (same task, real counts) is the only benchmark
       shown; the raw-size ceiling table was removed 2026-07-20 because it
       invited overstatement. Every number here is reproducible by the reader. -->
  <section id="proof" class="relative py-32 px-6 bg-surface border-y border-border overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 right-1/4 w-[45%] h-72 bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="section-reveal text-center mb-14">
        <SectionEyebrow num="04" label="PROOF" />
        <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Measured, not claimed.</h2>
        <p class="text-secondary max-w-2xl mx-auto leading-relaxed">
          Knot's headline benefit for AI agents: one reads a repository's whole shape for a few thousand tokens, instead of paying several times that to list folders and open files to find its bearings. Every number below is reproducible on your own machine.
        </p>
      </div>

      <!-- The A/B benchmark (the defensible centrepiece). -->
      <div class="section-reveal mb-6">
        <p class="text-accent text-xs font-mono tracking-widest mb-3 text-center">THE BENCHMARK · SAME REPO · SAME QUESTION · SAME AGENT</p>
        <p class="text-secondary text-sm text-center max-w-2xl mx-auto mb-8">
          A 56-file Python codebase the agent had never read. The question, both times:
          <span class="text-primary/90">“What is this project, what are its main components, and where would a new forecasting model go?”</span> Both answers were correct against the source. Only the cost differed.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="p-6 rounded-2xl bg-bg border border-border">
            <p class="text-hint text-xs font-mono tracking-widest mb-3">WITHOUT KNOT</p>
            <p class="text-4xl font-black text-primary mb-1">≈ 5,185<span class="text-lg text-hint font-bold"> tokens</span></p>
            <p class="text-hint text-xs font-mono mb-4">5+ tool calls</p>
            <ul class="text-secondary text-sm space-y-1.5 leading-relaxed">
              <li>list the files · read the README</li>
              <li>open <code class="text-primary/70">base.py</code> · <code class="text-primary/70">registry.py</code> · a model</li>
              <li class="text-hint">…and that's granting perfect first-try file picks</li>
            </ul>
          </div>
          <div class="p-6 rounded-2xl bg-accent/[0.06] border border-accent/40">
            <p class="text-accent text-xs font-mono tracking-widest mb-3">WITH KNOT</p>
            <p class="text-4xl font-black text-accent mb-1">≈ 1,504<span class="text-lg text-accent/70 font-bold"> tokens</span></p>
            <p class="text-accent/70 text-xs font-mono mb-4">1 tool call</p>
            <ul class="text-secondary text-sm space-y-1.5 leading-relaxed">
              <li>one call to <code class="text-primary/80">knot_repo_map</code></li>
              <li>files ranked by importance, each with its symbols</li>
              <li class="text-primary/80">complete, correct answer</li>
            </ul>
          </div>
        </div>
        <p class="text-secondary text-sm text-center mt-6 max-w-2xl mx-auto leading-relaxed">
          <span class="text-primary font-semibold">≥ 3.4× fewer tokens, on a small repo, with every assumption biased against Knot.</span> The map is budget-capped (~2,000 tokens whether the repo has 56 files or 5,000), while ad-hoc exploration scales with the codebase, so the gap widens as projects grow.
        </p>
      </div>

      <!-- Verify it yourself, the third-party-checkable protocol.
           (The raw-size "ceiling" ratio table was removed 2026-07-20: the
           A/B above is the defensible number; the ceiling invited
           overstatement readings even with its honest label.) -->
      <div class="section-reveal mt-12 p-6 rounded-2xl bg-bg border border-border max-w-2xl mx-auto">
        <p class="text-accent text-xs font-mono tracking-widest mb-3">VERIFY IT YOURSELF</p>
        <p class="text-secondary text-sm leading-relaxed mb-3">
          Don't take our number. Generate your own. Run two fresh AI-agent sessions on the same repository: one with Knot's tools available, one without. Ask each the same orientation question, then compare the token cost the agent itself reports.
        </p>
        <p class="text-hint text-xs leading-relaxed">
          Metered by the agent's own billing, not by us.
        </p>
      </div>

      <p class="text-hint text-xs text-center mt-6 max-w-xl mx-auto leading-relaxed">
        Honest limits: the map doesn't replace reading code you're about to <em>edit</em>. It replaces the hunt for <em>which</em> code that is. Per-file symbol extraction currently covers Rust, Python, JavaScript/TypeScript, and Dart.
      </p>
    </div>
  </section>

  <!-- ── KNOT AI (bridge to the dedicated /knot-ai/ page) ──────────────────────
       Knot AI writes Knot's commit messages, so the Knot page names it once and
       links out. The full pitch, benchmark, training and files live on /knot-ai/;
       kept deliberately slim here to avoid duplicating that page. -->
  <section id="knot-ai" class="relative py-20 px-6 overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-56 bg-accent/[0.06] blur-3xl pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto">
      <div class="section-reveal flex flex-col md:flex-row items-center gap-6 p-6 md:p-8 rounded-2xl bg-surface border border-accent/25">
        <img src="/knot-ai-logo.png" alt="Knot AI" width="60" height="60" class="rounded-xl shrink-0" />
        <div class="flex-1 text-center md:text-left">
          <p class="text-accent text-xs font-mono tracking-widest mb-2">POWERED BY KNOT SCRIBE</p>
          <h3 class="text-xl font-bold text-primary mb-1.5">Every commit message is written on-device.</h3>
          <p class="text-secondary text-sm leading-relaxed">
            The messages Knot writes come from <span class="text-primary">Knot Scribe</span>: our open, on-device model that reads the diff and writes the message, also released standalone on Hugging Face and Ollama.
          </p>
        </div>
        <a href="/knot-ai/" class="group shrink-0 inline-flex items-center gap-1.5 px-6 py-3 rounded-xl bg-accent text-bg font-bold text-sm hover:bg-white transition-all hover:scale-105">
          Explore Knot AI <span class="group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── 05 WHO IT'S FOR ──────────────────────────────────────────────────── -->
  <section id="audiences" class="relative py-32 px-6 max-w-6xl mx-auto">
    <div aria-hidden="true" class="absolute top-0 left-1/4 w-[40%] h-64 bg-accent/[0.05] blur-3xl pointer-events-none"></div>

    <div class="section-reveal text-center mb-16">
      <SectionEyebrow num="05" label="WHO IT'S FOR" />
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Three audiences, one tool.</h2>
      <p class="text-secondary max-w-xl mx-auto leading-relaxed">
        The same install, three very different reasons to want it.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <div class="p-6 rounded-2xl bg-surface border border-accent/30 glow-border">
