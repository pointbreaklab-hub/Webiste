---
import Base from '../../layouts/Base.astro';
import Nav  from '../../components/Nav.astro';
import '../../styles/global.css';
---

<Base
  title="Add me on Whispr"
  description="A friend wants to chat with you on Whispr — the private, serverless messenger."
>
  <Nav />

  <main class="min-h-screen flex items-center justify-center px-6 pt-24 pb-12">
    <div class="max-w-md w-full text-center">

      <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-accent flex items-center justify-center">
        <span class="text-3xl">🔒</span>
      </div>

      <h1 class="text-3xl md:text-4xl font-black text-primary mb-3">Add me on Whispr</h1>
      <p class="text-secondary leading-relaxed mb-8">
        A friend has invited you to a private conversation on Whispr — the serverless, end-to-end encrypted messenger.
      </p>

      <!-- App-installed path: visible immediately if the app handles whispr:// links -->
      <noscript>
        <p class="text-warning mb-6 text-sm">JavaScript is required to open the app or get the download link.</p>
      </noscript>

      <!-- Expired-link path: shown if `t` query param is in the past -->
      <div id="expired-prompt" class="hidden mb-6">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-yellow-500/10 border border-yellow-500/30 text-yellow-500 text-xs font-mono mb-4">
          <span>⏱</span>
          <span>Link expired</span>
        </div>
        <p class="text-secondary leading-relaxed mb-2">
          This Whispr invite link is no longer valid.
        </p>
        <p class="text-hint text-sm">
          Ask the person who sent it for a fresh one.
        </p>
      </div>

      <div id="open-app" class="hidden mb-6">
        <a id="open-app-link"
           class="inline-block px-6 py-3 rounded-xl bg-accent text-bg font-semibold hover:bg-white transition">
          Open in Whispr
        </a>
      </div>

      <!-- App-not-installed path: download CTA + how-it-works -->
      <div id="install-prompt">
        <p class="text-hint text-sm mb-4">Don't have Whispr yet?</p>
        <a href="/downloads/whispr-android.apk"
           class="inline-block px-6 py-3 rounded-xl bg-accent text-bg font-semibold hover:bg-white transition mb-3">
          Download Whispr for Android
        </a>
        <p class="text-hint text-xs">
          iOS coming soon. After you install Whispr, tap the invite link again to add your contact.
        </p>
      </div>

      <div class="mt-12 pt-8 border-t border-border text-left text-xs text-hint space-y-2">
        <p><span class="text-primary">Private by default:</span> No accounts, no servers, no metadata.</p>
        <p><span class="text-primary">End-to-end encrypted:</span> Same Signal Protocol the journalists use.</p>
        <p><span class="text-primary">Free forever:</span> No ads, no tracking, no compromise.</p>
      </div>
    </div>
  </main>

  <script>
    // Forward the query params (k, n, t) into a whispr:// link and try to
    // open it. If the link's expiry timestamp `t` is in the past, show the
    // "expired" view instead of the auto-redirect / install CTAs.
    const params = new URLSearchParams(window.location.search);
    const k  = params.get('k');
    const n  = params.get('n');
    const o  = params.get('o');   // sender's .onion — used for round-trip notification
    const sk = params.get('sk');  // signed pre-key (hex) — required for X3DH
    const ss = params.get('ss');  // SPK signature (hex)
    const t  = params.get('t');

    const expiredEl = document.getElementById('expired-prompt');
    const openBtn   = document.getElementById('open-app');
    const installEl = document.getElementById('install-prompt');

    const tNum = t ? Number(t) : 0;
    const isExpired = tNum > 0 && Date.now() > tNum;

    if (isExpired) {
      // Hide everything except the expired notice.
      expiredEl?.classList.remove('hidden');
      installEl?.classList.add('hidden');
    } else if (k && /^[0-9a-fA-F]{64}$/.test(k)) {
      const out = new URLSearchParams();
      out.set('k', k);
      if (n)  out.set('n',  n);
      if (o)  out.set('o',  o);
      if (sk) out.set('sk', sk);
      if (ss) out.set('ss', ss);
      if (t)  out.set('t',  t);
      const appUrl = `whispr://add?${out.toString()}`;

      const link = document.getElementById('open-app-link') as HTMLAnchorElement;
      if (link) link.href = appUrl;
      if (openBtn) openBtn.classList.remove('hidden');

      // Auto-attempt to open the app (browsers will silently do nothing
      // if the scheme isn't registered — no error shown to the user).
      window.addEventListener('load', () => {
        setTimeout(() => { window.location.href = appUrl; }, 250);
      });
    }
  </script>
</Base>
