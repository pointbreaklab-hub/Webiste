---
import Base        from '../layouts/Base.astro';
import Nav         from '../components/Nav.astro';
import Hero        from '../components/Hero.astro';
import AppCard     from '../components/AppCard.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import DownloadButton from '../components/DownloadButton.astro';
import Footer      from '../components/Footer.astro';
import '../styles/global.css';
---

<Base>
  <Nav />
  <Hero />

  <!-- ── APPS ──────────────────────────────────────────────────────────── -->
  <section id="apps" class="py-32 px-6 max-w-7xl mx-auto">
    <div class="section-reveal text-center mb-16">
      <p class="text-accent text-xs font-mono tracking-widest mb-3">THE LAB</p>
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">What We Build</h2>
      <p class="text-secondary max-w-xl mx-auto leading-relaxed">
        Every application from PointBreakLab is built on the same principle — your data belongs to you.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <AppCard
        name="Whispr"
        tagline="PRIVATE BY DEFAULT"
        description="A messenger built so your conversations actually belong to you. No accounts, no servers, no phone numbers."
        icon="🔒"
        href="#whispr"
        active={true}
      />
      <AppCard
        name="Knot"
        tagline="SECURE NOTES · COMING SOON"
        description="End-to-end encrypted notes that live only on your device. No cloud sync, no account required."
        icon="📝"
      />
      <AppCard
        name="????"
        tagline="IN DEVELOPMENT"
        description="The next tool from PointBreakLab. Privacy-first, as always."
        icon="⬡"
      />
    </div>
  </section>

  <!-- ── WHISPR ─────────────────────────────────────────────────────────── -->
  <section id="whispr" class="py-32 px-6 max-w-7xl mx-auto">

    <!-- What it is -->
    <div class="section-reveal text-center mb-20">
      <p class="text-accent text-xs font-mono tracking-widest mb-3">WHISPR</p>
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-6 leading-tight">
        Your messages,<br class="hidden md:block"/> only yours.
      </h2>
      <p class="text-secondary max-w-2xl mx-auto leading-relaxed">
        A messenger that doesn't need an account, a phone number, or even an internet connection. Your conversations travel directly between devices, encrypted end-to-end before they ever leave your hands.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-28">
      <FeatureBlock
        icon="🌐"
        title="Zero Servers"
        description="Messages travel peer to peer. There is no company server to subpoena, no database to breach, no authority to comply with."
      />
      <FeatureBlock
        icon="🔐"
        title="Signal Protocol"
        description="X3DH + Double Ratchet. The same cryptography trusted by journalists, activists, and governments worldwide."
      />
      <FeatureBlock
        icon="📡"
        title="Works Offline"
        description="Bluetooth LE mesh delivers messages with no internet. At a protest, on a plane, in a blackout — anywhere."
      />
      <FeatureBlock
        icon="🧅"
        title="Tor Routing"
        description="Route messages through the Tor network for anonymised delivery. Your IP is never exposed to peers."
      />
      <FeatureBlock
        icon="📧"
        title="Encrypted Email"
        description="ECIES-encrypted email between Whispr users. Threads, reply-all, forward — with full E2EE, no central server."
      />
      <FeatureBlock
        icon="🆔"
        title="No Account"
        description="Your identity is a locally-generated Ed25519 key pair. No email, no phone, no registration of any kind."
      />
    </div>

    <!-- How it works -->
    <div class="section-reveal mb-20">
      <p class="text-accent text-xs font-mono tracking-widest mb-3 text-center">HOW IT WORKS</p>
      <h3 class="text-2xl md:text-3xl font-black text-primary mb-12 text-center">Three steps. Completely private.</h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '01', title: 'Encrypt on device', body: 'Your message is encrypted on your device before it ever leaves. Only the recipient\'s Ed25519 key can decrypt it.' },
          { step: '02', title: 'Travel the best path', body: 'The app automatically picks the fastest available route — direct LAN, Tor hidden service, or BLE mesh.' },
          { step: '03', title: 'Decrypt on arrival', body: 'Only your contact\'s device decrypts the message. Not us, not your ISP, not anyone in between.' },
        ].map(({ step, title, body }) => (
          <div class="section-reveal relative pl-8 border-l border-border hover:border-accent/40 transition-colors">
            <span class="absolute -left-px top-0 w-0.5 h-8 bg-accent"></span>
            <p class="text-accent font-mono text-xs mb-2">{step}</p>
            <h4 class="text-lg font-bold text-primary mb-2">{title}</h4>
            <p class="text-secondary text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Three transports -->
    <div class="section-reveal">
      <p class="text-accent text-xs font-mono tracking-widest mb-3 text-center">TRANSPORT LAYER</p>
      <h3 class="text-2xl md:text-3xl font-black text-primary mb-12 text-center">Three ways to reach anyone.</h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { icon: '🏠', label: 'LAN', title: 'Local Network', body: 'When on the same Wi-Fi, messages travel directly — sub-second delivery, zero internet required.' },
          { icon: '🧅', label: 'TOR', title: 'Tor Network',   body: 'Route through Tor hidden services for anonymous, censorship-resistant delivery across the internet.' },
          { icon: '📶', label: 'BLE', title: 'BLE Mesh',      body: 'Bluetooth Low Energy mesh. Send messages nearby with no Wi-Fi, no internet, no infrastructure at all.' },
        ].map(({ icon, label, title, body }) => (
          <div class="p-6 rounded-2xl bg-surface border border-border hover:border-accent/30 transition-colors text-center group">
            <div class="text-4xl mb-4">{icon}</div>
            <div class="inline-block px-2 py-0.5 rounded bg-accent/10 text-accent text-xs font-mono mb-3">{label}</div>
            <h4 class="text-base font-bold text-primary mb-2">{title}</h4>
            <p class="text-secondary text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SECURITY ───────────────────────────────────────────────────────── -->
  <section id="security" class="py-32 px-6 bg-surface border-y border-border">
    <div class="max-w-4xl mx-auto">
      <div class="section-reveal text-center mb-16">
        <p class="text-accent text-xs font-mono tracking-widest mb-3">ARCHITECTURE</p>
        <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Built right, by default.</h2>
        <p class="text-secondary max-w-xl mx-auto">
          Whispr uses the same cryptography Signal uses, with one difference: there's no server in the middle. Even we couldn't read your messages if we wanted to.
        </p>
      </div>

      <div class="section-reveal font-mono text-sm rounded-2xl bg-bg border border-border overflow-hidden">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
          <div class="w-3 h-3 rounded-full bg-error/70"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-accent/70"></div>
          <span class="ml-2 text-hint text-xs">security-architecture.txt</span>
        </div>
        <div class="p-6 space-y-2.5 text-xs md:text-sm leading-relaxed overflow-x-auto">
          {[
            ['Identity',         'Ed25519 key pair · generated on-device · stored in hardware enclave'],
            ['Key Exchange',     'X3DH (Extended Triple Diffie-Hellman) · forward secrecy'],
            ['Message Crypto',   'Double Ratchet · AES-256-GCM · per-message keys'],
            ['Transport Crypto', 'ECIES outer envelope · AES-GCM UDP discovery'],
            ['Email Crypto',     'ECIES pairwise encryption to recipient Ed25519 identity key'],
            ['Database',         'SQLCipher · AES-256 · full file encryption on mobile'],
            ['Password',         'PBKDF2-SHA512 · 200,000 iterations · 256-bit key'],
            ['Metadata',         'Random padding · ECIES envelope · sender/receiver hidden on wire'],
            ['Server',           'None'],
          ].map(([key, val]) => (
            <div class="flex gap-4 items-baseline">
              <span class="text-hint shrink-0 w-36">{key}</span>
              <span class="text-accent">→</span>
              <span class="text-primary/80">{val}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── UPDATES ───────────────────────────────────────────────────────── -->
  <section id="updates" class="py-32 px-6 max-w-4xl mx-auto">
    <div class="section-reveal text-center mb-16">
      <p class="text-accent text-xs font-mono tracking-widest mb-3">WHAT'S COMING</p>
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Updates</h2>
      <p class="text-secondary max-w-xl mx-auto leading-relaxed">
        PointBreakLab ships continuously. Here's what's in the pipeline.
      </p>
    </div>

    <div class="space-y-4">
      {[
        {
          tag: 'WHISPR · IN PROGRESS',
          title: 'Voice & Video Calls',
          body: 'End-to-end encrypted peer-to-peer calls over LAN and Tor. No relay server, no recording, no third party.',
          status: 'building',
        },
        {
          tag: 'WHISPR · PLANNED',
          title: 'Group Messaging',
          body: 'Multi-party encrypted group chats using a shared group key, derived without a central key server.',
          status: 'planned',
        },
        {
          tag: 'KNOT · COMING SOON',
          title: 'Knot — Encrypted Notes',
          body: 'Device-only encrypted notes. No sync, no cloud, no account. Ships after Whispr 1.0 stabilises.',
          status: 'soon',
        },
        {
          tag: 'WHISPR · PLANNED',
          title: 'Self-Destructing Messages',
          body: 'Per-message timers. Messages evaporate from both devices after the set duration — no trace left.',
          status: 'planned',
        },
      ].map(({ tag, title, body, status }) => (
        <div class="section-reveal flex gap-5 p-6 rounded-2xl bg-surface border border-border hover:border-accent/30 transition-colors">
          <div class={`mt-1 w-2 h-2 rounded-full shrink-0 ${status === 'building' ? 'bg-accent animate-pulse' : status === 'soon' ? 'bg-yellow-500/70' : 'bg-hint'}`}></div>
          <div>
            <p class="text-hint text-xs font-mono mb-1">{tag}</p>
            <h3 class="text-base font-bold text-primary mb-1.5">{title}</h3>
            <p class="text-secondary text-sm leading-relaxed">{body}</p>
          </div>
          <div class={`ml-auto shrink-0 self-start px-2 py-0.5 rounded text-xs font-mono ${status === 'building' ? 'bg-accent/10 text-accent' : 'bg-surface border border-border text-hint'}`}>
            {status === 'building' ? 'building' : status === 'soon' ? 'soon' : 'planned'}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── DOWNLOAD ───────────────────────────────────────────────────────── -->
  <section id="download" class="py-32 px-6 bg-surface border-y border-border">
    <div class="max-w-2xl mx-auto text-center">
      <div class="section-reveal">
        <p class="text-accent text-xs font-mono tracking-widest mb-3">GET WHISPR</p>
        <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Download Whispr</h2>
        <p class="text-secondary mb-10">Available for Android. iOS coming soon. No account. No tracking. Just install and go.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
          <DownloadButton platform="android" href="/downloads/whispr-android.apk" label="Android APK" />
          <DownloadButton platform="ios"     href="#" label="iOS — Coming Soon" />
        </div>

        <div class="text-left p-5 rounded-2xl bg-bg border border-border font-mono text-xs space-y-1.5">
          <div class="flex gap-3"><span class="text-hint w-32">Version</span><span class="text-primary">1.0.0</span></div>
          <div class="flex gap-3"><span class="text-hint w-32">Released</span><span class="text-primary">2026</span></div>
          <div class="flex gap-3"><span class="text-hint w-32">Cost</span><span class="text-primary/80">Free. No accounts, no ads, no tracking.</span></div>
          <div class="flex gap-3 mt-3 pt-3 border-t border-border"><span class="text-hint w-32">SHA-256 (APK)</span><span class="text-primary/60 break-all">fceb5a276b3a3caa50f9d9784b1e2626a39d0d37326e33fbd2bf46a4a737ade0</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ABOUT ──────────────────────────────────────────────────────────── -->
  <section id="about" class="py-32 px-6 max-w-5xl mx-auto">
    <div class="section-reveal grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

      <div>
        <p class="text-accent text-xs font-mono tracking-widest mb-3">THE STUDIO</p>
        <h2 class="text-3xl md:text-4xl font-black text-primary mb-6">About PointBreakLab</h2>
        <p class="text-secondary leading-relaxed mb-5">
          PointBreakLab is a studio building privacy-first applications. Every app ships free, with zero access to your data — by design, not by policy.
        </p>
        <p class="text-secondary leading-relaxed mb-8">
          Every tool starts from the same question: what would this app look like if we genuinely had no access to your data? Whispr is the answer for communication.
        </p>
        <div id="contact" class="flex gap-4">
          <a href="mailto:mail.roshankumargupta@gmail.com"
             class="px-5 py-2.5 rounded-xl bg-surface border border-border text-sm text-secondary hover:border-accent hover:text-primary transition-all">
            Contact
          </a>
        </div>
      </div>

      <div class="flex flex-col items-center gap-4">
        <!-- Profile placeholder — replace src with your photo -->
        <div class="w-44 h-44 rounded-full bg-surface border-2 border-accent/30 glow-border flex items-center justify-center animate-glow-pulse">
          <span class="text-4xl font-black text-gradient select-none">RG</span>
        </div>
        <div class="text-center">
          <p class="text-primary font-bold">Roshan Kumar Gupta</p>
          <p class="text-secondary text-sm">Software Engineer · PointBreakLab</p>
        </div>
        <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-accent/5 border border-accent/20">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
          <span class="text-accent text-xs font-mono">Building in public</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
