---
import Base           from '../layouts/Base.astro';
import Nav            from '../components/Nav.astro';
import Hero           from '../components/Hero.astro';
import AppCard        from '../components/AppCard.astro';
import Footer         from '../components/Footer.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
import '../styles/global.css';
---

<Base>
  <Nav />
  <Hero />

  <!-- ── 01 THE LAB — apps lineup ──────────────────────────────────────── -->
  <section id="apps" class="relative py-32 px-6 max-w-7xl mx-auto">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-64 bg-accent/[0.07] blur-3xl pointer-events-none"></div>
    <div class="section-reveal text-center mb-16">
      <SectionEyebrow num="01" label="THE LAB" />
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">What we build</h2>
      <p class="text-secondary max-w-xl mx-auto leading-relaxed">
        Every application from PointBreakLab is built on the same principle — your data belongs to you.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <AppCard
        name="Whispr"
        tagline="PRIVATE BY DEFAULT"
        description="A messenger built so your conversations actually belong to you. No accounts, no servers, no phone numbers."
        icon="🔒"
        href="/whispr/"
        active={true}
      />
      <AppCard
        name="Heart"
        tagline="LOCAL-FIRST WELLNESS"
        description="A wellness app for Bluetooth heart-rate bands. HR, HRV, sleep stages, recovery, strain — all on-device. No account, no cloud, no subscription."
        icon="❤️"
        href="/heart/"
        active={true}
      />
      <AppCard
        name="Knot"
        tagline="PEER-TO-PEER VERSION CONTROL"
        description="Save a file. A few seconds later it's a real commit on every teammate's machine. No GitHub account, no central server, no four-step push ritual — peer-to-peer over Tor."
        icon="🪢"
        href="/knot/"
        active={true}
        status="TESTING"
      />
      <AppCard
        name="Elixir"
        tagline="OFFLINE VAULT · COMING LATER"
        description="An encrypted secrets vault — passwords, recovery codes, anything you'd lose sleep over leaking. Lives only on your device."
        icon="🧪"
      />
    </div>
  </section>

  <!-- ── 02 PROOF ──────────────────────────────────────────────────────────
       Receipts for the privacy claims in the hero. Privacy products carry a
       higher proof burden than most product claims because users can't
       verify them by using the product — only by inspecting the
       architecture. The full architecture lives at /whispr/#architecture;
       this is a compact excerpt so the homepage shows evidence, not just
       claims. (Added 2026-05-07 after homepage-split review.) Don't strip
       this back — competitors (Signal, Session, Briar, SimpleX) all lead
       with cryptographic architecture above the fold.                    -->
  <section id="proof" class="relative py-32 px-6 bg-surface border-y border-border overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[70%] h-72 bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto">
      <div class="section-reveal text-center mb-12">
        <SectionEyebrow num="02" label="PROOF" />
        <h2 class="text-3xl md:text-5xl font-light text-primary mb-4 tracking-tight">Receipts, not claims.</h2>
        <p class="text-secondary max-w-xl mx-auto leading-relaxed">
          Privacy claims need evidence. These guarantees hold for every PointBreakLab app — by architectural choice, not company policy.
        </p>
      </div>

      <div class="section-reveal font-mono text-sm rounded-2xl bg-bg border border-border overflow-hidden">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
          <div class="w-3 h-3 rounded-full bg-error/70"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-accent/70"></div>
          <span class="ml-2 text-hint text-xs">stack.txt</span>
        </div>
        {/* Studio-level guarantees only — what's true of EVERY PBL app
            (Whispr, Heart, Knot, Elixir). Whispr-specific primitives like
            X3DH, Double Ratchet, and the ECIES wire envelope live on
            /whispr/#architecture because they're messaging-only and would
            misrepresent the other apps. The link below sends interested
            visitors there. (Generalised 2026-05-08 after a review pointed
            out the homepage panel was Whispr-specific in disguise.) */}
        <div class="p-6 space-y-2.5 text-xs md:text-sm leading-relaxed overflow-x-auto">
          {[
            ['Storage',     'SQLCipher · AES-256 · full-file encryption · on device'],
            ['Server',      'None · peer-to-peer or local-only by design'],
            ['Accounts',    'None · no email, no phone, no registration'],
            ['Telemetry',   'None · no analytics, no crash reports, no usage pings'],
            ['Trust model', 'Open algorithms · architecture, not policy'],
          ].map(([key, val]) => (
            <div class="flex gap-4 items-baseline">
              <span class="text-hint shrink-0 w-32">{key}</span>
              <span class="text-accent">→</span>
              <span class="text-primary/80">{val}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="section-reveal text-center mt-10">
        <a
          href="/whispr/#architecture"
          class="inline-flex items-center gap-2 text-accent text-sm font-semibold hover:gap-3 transition-all"
        >
          Per-app cryptography (Whispr's Signal Protocol stack, etc.) <span>→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── 03 THE STUDIO ─────────────────────────────────────────────────── -->
  <section id="about" class="relative py-32 px-6 max-w-5xl mx-auto">
    <div aria-hidden="true" class="absolute top-0 left-0 w-[40%] h-64 bg-accent/[0.05] blur-3xl pointer-events-none"></div>
    <div class="section-reveal grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

      <div>
        <div class="mb-3"><SectionEyebrow num="03" label="THE STUDIO" align="left" /></div>
        <h2 class="text-3xl md:text-4xl font-black text-primary mb-6">About PointBreakLab</h2>
        <p class="text-secondary leading-relaxed mb-5">
          PointBreakLab is a studio building privacy-first applications. Every app ships free, with zero access to your data — by design, not by policy.
        </p>
        <p class="text-secondary leading-relaxed mb-8">
          Every tool starts from the same question: what would this app look like if we genuinely had no access to your data? Whispr is the answer for communication.
        </p>
        <div id="contact" class="flex gap-4">
          <a href="mailto:mail.roshankumargupta@gmail.com"
             class="px-5 py-2.5 rounded-xl bg-surface border border-border text-sm text-secondary hover:border-accent hover:text-primary transition-all">
            Contact
          </a>
        </div>
      </div>

      <div class="flex flex-col items-center gap-4">
        <img
          src="/roshan.jpg"
          alt="Roshan Kumar Gupta"
          width="176"
          height="176"
          loading="lazy"
          class="w-44 h-44 rounded-full object-cover border-2 border-accent/30 glow-border animate-glow-pulse"
        />
        <div class="text-center">
          <p class="text-primary font-bold">Roshan Kumar Gupta</p>
          <p class="text-secondary text-sm">Software Engineer · PointBreakLab</p>
          <!-- JMU affiliation: official UNI WÜ mark + historic seal + name. -->
          <a
            href="https://www.uni-wuerzburg.de/en/"
            target="_blank"
            rel="noopener noreferrer"
            title="Julius-Maximilians-Universität Würzburg"
            class="group flex flex-col items-center gap-2 mt-2.5 hover:opacity-90 transition-opacity"
          >
            <div class="flex items-center justify-center gap-2">
              <img src="/jmu-uniwue.png" alt="Julius-Maximilians-Universität Würzburg" width="32" height="32" loading="lazy" class="h-8 w-8 rounded-[6px]" />
              <span class="text-secondary text-sm group-hover:text-primary transition-colors">Julius-Maximilians</span>
            </div>
          </a>
          <p class="text-hint text-xs font-mono mt-1.5">📍 Würzburg, Germany</p>
          <a
            href="https://www.openstreetmap.org/?mlat=49.7913&mlon=9.9534#map=12/49.7913/9.9534"
            target="_blank"
            rel="noopener noreferrer"
            title="Würzburg, Germany — open in OpenStreetMap"
            class="group block mx-auto mt-3 w-44 rounded-xl overflow-hidden border border-border hover:border-accent/50 transition-colors"
          >
            <img
              src="/wuerzburg-map.png"
              alt="Map showing Würzburg, Germany"
              width="176"
              height="176"
              loading="lazy"
              class="w-44 h-44 object-cover group-hover:scale-[1.03] transition-transform duration-300"
            />
          </a>
          <p class="text-[10px] text-hint mt-1">
            © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer" class="hover:text-accent">OpenStreetMap</a> contributors
          </p>
        </div>
        <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-accent/5 border border-accent/20">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
          <span class="text-accent text-xs font-mono">Building in public</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 04 COMMUNITY — async conversation, backed by GitHub Discussions ──────
       Giscus widget. Source of truth = Discussions in pointbreaklab-hub/Webiste.
       Lazy-loaded (IntersectionObserver) so the third-party client.js never
       touches the initial-load JS budget. Giscus is open-source + tracker-free
       — the one sanctioned third-party script on the site. To POST, a visitor
       signs in with GitHub (reading is open to all). -->
  <section id="conversation" class="relative py-32 px-6 max-w-3xl mx-auto">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-64 bg-accent/[0.07] blur-3xl pointer-events-none"></div>
    <div class="section-reveal text-center mb-12">
      <SectionEyebrow num="04" label="COMMUNITY" />
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Join the conversation.</h2>
      <p class="text-secondary max-w-xl mx-auto leading-relaxed">
        Questions, feedback, ideas — talk to us and to each other, right here. Threads are public and powered by GitHub Discussions; sign in with a GitHub account to post.
      </p>
    </div>
    <div class="section-reveal rounded-2xl bg-surface border border-border p-4 md:p-8 min-h-[180px]">
      <div id="giscus-container"></div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var section = document.getElementById('conversation');
      var mount = document.getElementById('giscus-container');
      if (!section || !mount) return;
      var loaded = false;
      function loadGiscus() {
        if (loaded) return; loaded = true;
        var s = document.createElement('script');
        s.src = 'https://giscus.app/client.js';
        s.setAttribute('data-repo', 'pointbreaklab-hub/Webiste');
        s.setAttribute('data-repo-id', 'R_kgDOSUvnLA');
        s.setAttribute('data-category', 'General');
        s.setAttribute('data-category-id', 'DIC_kwDOSUvnLM4C_b6T');
        s.setAttribute('data-mapping', 'specific');
        s.setAttribute('data-term', 'PointBreakLab Community');
        s.setAttribute('data-strict', '0');
        s.setAttribute('data-reactions-enabled', '1');
        s.setAttribute('data-emit-metadata', '0');
        s.setAttribute('data-input-position', 'top');
        s.setAttribute('data-theme', 'https://pointbreaklab.com/giscus-theme.css');
        s.setAttribute('data-lang', 'en');
        s.setAttribute('data-loading', 'lazy');
        s.crossOrigin = 'anonymous';
        s.async = true;
        mount.appendChild(s);
      }
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) { loadGiscus(); io.disconnect(); } });
        }, { rootMargin: '300px' });
        io.observe(section);
      } else {
        loadGiscus();
      }
    })();
  </script>

  <Footer />
</Base>
