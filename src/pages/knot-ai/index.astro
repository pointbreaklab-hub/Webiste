---
import Base           from '../../layouts/Base.astro';
import Nav            from '../../components/Nav.astro';
import Footer         from '../../components/Footer.astro';
import SectionEyebrow from '../../components/SectionEyebrow.astro';
import '../../styles/global.css';

// One consistent benchmark everywhere (3 models x 2 gold sets of 60, scored
// through the shipping GGUF path). Same numbers as the HF + Ollama model cards.
const metrics = [
  ['Type accuracy',      '0.0%', '40.0%', '55.0%'],
  ['Title word-overlap', '0.4%', '18.3%', '30.3%'],
  ['Exact title',        '0.0%', '0.0%',  '6.7%'],
  ['Scope accuracy',     '0.0%', '70.0%', '75.0%'],
  ['Unparseable / 60',   '59',   '4',     '0'],
];
const byType = [
  ['chore', 6, '83%', '100%'], ['ci', 6, '67%', '100%'], ['feat', 6, '33%', '83%'],
  ['fix', 6, '67%', '83%'],    ['test', 5, '80%', '80%'], ['docs', 6, '83%', '67%'],
  ['perf', 6, '0%', '50%'],    ['build', 5, '0%', '0%'],  ['refactor', 6, '0%', '0%'],
  ['style', 6, '0%', '0%'],    ['revert', 2, '0%', '0%'],
];
const byLang = [ { lang: 'Rust', val: 55 }, { lang: 'Go', val: 45 }, { lang: 'Python', val: 60 } ];
---

<Base
  title="Knot AI · the on-device model that writes your git commits"
  description="Knot AI reads a git diff and writes the commit message — a local Qwen2.5-Coder-7B fine-tune, open on Hugging Face and Ollama. Runs 100% on your machine, no API. Conventional-Commit output."
>
  <Nav />

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="relative pt-32 pb-20 px-6 overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-[28rem] bg-accent/[0.08] blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/30 bg-accent/5 text-accent text-xs font-mono tracking-wider mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        OPEN MODEL · APACHE-2.0 · RUNS ON YOUR MACHINE
      </div>

      <div class="flex items-center justify-center gap-4 mb-6">
        <img src="/knot-ai-logo.png" alt="Knot AI" width="64" height="64" class="rounded-2xl" />
        <span class="text-2xl font-black text-primary tracking-tight">Knot AI</span>
      </div>

      <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6">
        <span class="text-primary">The model that</span><br/>
        <span class="text-gradient">writes your commits.</span>
      </h1>

      <p class="text-lg text-secondary font-light max-w-xl mx-auto leading-relaxed mb-3">
        Knot AI reads a git diff and writes the commit message for you — a clear, correctly-typed Conventional-Commit message. It's a task-specific fine-tune of Qwen2.5-Coder-7B that does one thing well.
      </p>
      <p class="text-sm text-accent font-mono mb-8">
        100% on your machine · no API · no code leaves your device.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
        <a href="https://ollama.com/pointbreaklab/knot-ai" target="_blank" rel="noopener"
           class="px-8 py-3.5 rounded-xl bg-accent text-bg font-bold text-sm hover:bg-white transition-all hover:scale-105 hover:shadow-[0_0_32px_rgba(0,212,170,0.4)]">
          🦙 Get on Ollama
        </a>
        <a href="https://huggingface.co/pointbreaklab/knot-ai" target="_blank" rel="noopener"
           class="px-8 py-3.5 rounded-xl border border-border text-secondary text-sm hover:border-accent hover:text-primary transition-all">
          🤗 Hugging Face
        </a>
      </div>

      <p class="inline-flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-xs font-mono text-hint">
        <span class="text-primary/80">git diff</span>
        <span class="text-accent">→</span>
        <span class="text-primary/80">Qwen2.5-Coder-7B + Knot AI LoRA</span>
        <span class="text-accent">→</span>
        <span class="text-primary/80">fix: prevent division by zero</span>
      </p>
    </div>
  </section>

  <!-- ── 01 HOW IT WORKS ──────────────────────────────────────────────────── -->
  <section id="how" class="relative py-28 px-6 bg-surface border-y border-border overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-72 bg-accent/[0.07] blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="section-reveal text-center mb-16">
        <SectionEyebrow num="01" label="HOW IT WORKS" />
        <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Diff in, commit out.</h2>
        <p class="text-secondary max-w-xl mx-auto leading-relaxed">
          No chat, no prompting. It reads the change and returns a structured message — the same contract it was trained and evaluated against.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '01', title: 'Reads your diff', body: 'It takes the git diff — plus a little file context for big multi-file changes — packed so the model sees the whole commit\'s scope, not just the first file.' },
          { step: '02', title: 'Runs on your hardware', body: 'Qwen2.5-Coder-7B with the Knot AI LoRA, served locally by llama.cpp or Ollama. Metal, CUDA, or CPU — same model file, same output, only speed scales. Works offline.' },
          { step: '03', title: 'Writes the message', body: 'Structured JSON output constrained to {title, body} — a correctly-typed Conventional-Commit subject and body, with fabricated issue-refs and sign-offs stripped.' },
        ].map(({ step, title, body }) => (
          <div class="section-reveal relative pl-8 border-l border-border hover:border-accent/40 transition-colors">
            <span class="absolute -left-px top-0 w-0.5 h-8 bg-accent"></span>
            <p class="text-accent font-mono text-xs mb-2">{step}</p>
            <h4 class="text-lg font-bold text-primary mb-2">{title}</h4>
            <p class="text-secondary text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>

      <p class="text-center text-hint text-xs mt-12 max-w-xl mx-auto leading-relaxed">
        It's the model behind <a href="/knot/" class="text-accent hover:underline">Knot</a>'s hands-free auto-commit — but it's open and standalone, so you can point it at any git workflow.
      </p>
    </div>
  </section>

  <!-- ── 02 BENCHMARK ─────────────────────────────────────────────────────── -->
  <section id="benchmark" class="relative py-32 px-6 max-w-4xl mx-auto">
    <div aria-hidden="true" class="absolute top-0 right-1/4 w-[45%] h-72 bg-accent/[0.07] blur-3xl pointer-events-none"></div>
    <div class="section-reveal text-center mb-14">
      <SectionEyebrow num="02" label="BENCHMARK" />
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Measured, not claimed.</h2>
      <p class="text-secondary max-w-2xl mx-auto leading-relaxed">
        Two held-out gold sets of 60 hand-reviewed commits, scored through the shipping model. Three models under one harness: the untouched base, the prior release (v3, JS/TS only), and today's model (v4, with added Rust / Go / Python).
      </p>
    </div>

    <!-- Fine-tuning ladder -->
    <div class="section-reveal rounded-2xl bg-bg border border-border p-6 md:p-8 mb-6">
      <p class="text-hint text-xs font-mono tracking-widest mb-6">TYPE ACCURACY — THE FINE-TUNING LADDER</p>
      {[
        { name: 'Base Qwen (zero-shot)', val: 0,  pct: '0%',  fill: 'bg-hint/40',   txt: 'text-hint',      note: '59/60 replies unparseable' },
        { name: 'Knot AI v3 (prior)',    val: 40, pct: '40%', fill: 'bg-accent/45', txt: 'text-secondary', note: 'JS/TS only' },
        { name: 'Knot AI (v4)',          val: 55, pct: '55%', fill: 'bg-accent',    txt: 'text-accent',    note: '0/60 errors' },
      ].map(({ name, val, pct, fill, txt, note }) => (
        <div class="flex items-center gap-3 md:gap-4 mb-4 last:mb-0">
          <span class="w-32 md:w-44 shrink-0 text-[11px] md:text-xs font-mono text-secondary text-right leading-tight">{name}</span>
          <div class="flex-1 h-7 rounded-md bg-surface border border-border overflow-hidden">
            <div class={`h-full ${fill} rounded-md`} style={`width:${val}%`}></div>
          </div>
          <span class={`w-10 shrink-0 text-xs font-mono ${txt}`}>{pct}</span>
          <span class="hidden md:block w-40 shrink-0 text-[11px] font-mono text-hint leading-tight">{note}</span>
        </div>
      ))}
      <p class="text-hint text-[11px] leading-relaxed mt-6 pt-4 border-t border-border/60">
        The base model isn't "bad at commits" — zero-shot with the same prompt it returns unstructured prose 59 times out of 60, so it can't be automated at all. Fine-tuning's first job is to make the reply reliably parseable; its second is to pick the right type.
      </p>
    </div>

    <!-- Full metrics table -->
    <div class="section-reveal rounded-2xl bg-bg border border-border overflow-hidden mb-6">
      <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
        <div class="w-3 h-3 rounded-full bg-error/70"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
        <div class="w-3 h-3 rounded-full bg-accent/70"></div>
        <span class="ml-2 text-hint text-xs font-mono">metrics.txt · 60 JS/TS gold</span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-xs md:text-sm font-mono">
          <thead>
            <tr class="text-hint border-b border-border">
              <th class="text-left font-normal p-3 md:px-5">Metric</th>
              <th class="text-right font-normal p-3 md:px-5">Base</th>
              <th class="text-right font-normal p-3 md:px-5">v3</th>
              <th class="text-right font-semibold p-3 md:px-5 text-accent">Knot AI</th>
            </tr>
          </thead>
          <tbody>
            {metrics.map(([metric, base, v3, knot]) => (
              <tr class="border-b border-border/50 last:border-0">
                <td class="text-secondary p-3 md:px-5">{metric}</td>
                <td class="text-hint text-right p-3 md:px-5">{base}</td>
                <td class="text-secondary text-right p-3 md:px-5">{v3}</td>
                <td class="text-accent text-right font-semibold p-3 md:px-5">{knot}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Full by-commit-type table (the complete breakdown) -->
    <div class="section-reveal rounded-2xl bg-bg border border-border overflow-hidden mb-6">
      <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
        <div class="w-3 h-3 rounded-full bg-error/70"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
        <div class="w-3 h-3 rounded-full bg-accent/70"></div>
        <span class="ml-2 text-hint text-xs font-mono">by-commit-type.txt · type accuracy · 60 JS/TS gold</span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-xs md:text-sm font-mono">
          <thead>
            <tr class="text-hint border-b border-border">
              <th class="text-left font-normal p-3 md:px-5">Type</th>
              <th class="text-right font-normal p-3 md:px-5">n</th>
              <th class="text-right font-normal p-3 md:px-5">v3</th>
              <th class="text-right font-semibold p-3 md:px-5 text-accent">Knot AI</th>
            </tr>
          </thead>
          <tbody>
            {byType.map(([type, n, v3, knot]) => (
              <tr class="border-b border-border/50 last:border-0">
                <td class="text-secondary p-3 md:px-5">{type}</td>
                <td class="text-hint text-right p-3 md:px-5">{n}</td>
                <td class="text-secondary text-right p-3 md:px-5">{v3}</td>
                <td class={`text-right font-semibold p-3 md:px-5 ${knot === '0%' ? 'text-hint' : 'text-accent'}`}>{knot}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Cross-language -->
    <div class="section-reveal rounded-2xl bg-bg border border-border p-6 md:p-8 mb-8">
      <p class="text-hint text-xs font-mono tracking-widest mb-2">GENERALIZES ACROSS LANGUAGES</p>
      <p class="text-secondary text-sm mb-6 leading-relaxed">
        Type accuracy on a <span class="text-primary/80">separate</span> 60-commit set of Rust / Go / Python — the languages this release added. The base model scores 0% on all three; Knot AI holds ~53% overall, close to its JS/TS score.
      </p>
      {byLang.map(({ lang, val }) => (
        <div class="flex items-center gap-3 md:gap-4 mb-3.5 last:mb-0">
          <span class="w-16 md:w-20 shrink-0 text-xs font-mono text-secondary text-right">{lang}</span>
          <div class="flex-1 h-6 rounded-md bg-surface border border-border overflow-hidden">
            <div class="h-full bg-accent rounded-md" style={`width:${val}%`}></div>
          </div>
          <span class="w-10 shrink-0 text-xs font-mono text-accent">{val}%</span>
        </div>
      ))}
    </div>

    <p class="section-reveal text-hint text-xs text-center max-w-2xl mx-auto leading-relaxed">
      Honest read: strong on the high-signal types (chore, ci, feat, fix, test), still developing on the genuinely ambiguous ones — refactor vs feat, build vs chore, style, revert — which the next release targets. These are single-reference scores (compared to one human label), so they understate real usefulness: a change scored a "miss" for not matching the exact human wording is still a correct, useful message.
    </p>
  </section>

  <!-- ── 03 TRAINING & FILES ──────────────────────────────────────────────── -->
  <section id="training" class="relative py-32 px-6 bg-surface border-y border-border overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-72 bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="section-reveal text-center mb-14">
        <SectionEyebrow num="03" label="TRAINING & FILES" />
        <h2 class="text-3xl md:text-5xl font-light text-primary mb-4 tracking-tight">Built in the open, on one GPU.</h2>
        <p class="text-secondary max-w-xl mx-auto leading-relaxed">
          A LoRA fine-tune of a permissively-licensed base, trained only on public commit history. No user data, no private code — ever.
        </p>
      </div>

      <div class="section-reveal font-mono text-sm rounded-2xl bg-bg border border-border overflow-hidden mb-6">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
          <div class="w-3 h-3 rounded-full bg-error/70"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-accent/70"></div>
          <span class="ml-2 text-hint text-xs">knot-ai-model.txt</span>
        </div>
        <div class="p-6 space-y-2.5 text-xs md:text-sm leading-relaxed overflow-x-auto">
          {[
            ['Base model',  'Qwen2.5-Coder-7B-Instruct · Apache-2.0'],
            ['Method',      'QLoRA (4-bit) · completion-only SFT (loss on the message only)'],
            ['Hardware',    'A single NVIDIA RTX 3060 (12 GB)'],
            ['Data',        '~3,227 diff→message pairs mined from permissive OSS · JS/TS, Python, Rust, Go'],
            ['Privacy',     'No user data · no private code · public commit history only'],
            ['Formats',     'LoRA adapter (PEFT safetensors) + LoRA GGUF (llama.cpp / Ollama)'],
            ['License',     'Apache-2.0 (derivative of Qwen2.5-Coder-7B)'],
          ].map(([key, val]) => (
            <div class="flex gap-4 items-baseline">
              <span class="text-hint shrink-0 w-28">{key}</span>
              <span class="text-accent">→</span>
              <span class="text-primary/80">{val}</span>
            </div>
          ))}
        </div>
      </div>

      <p class="text-hint text-xs text-center max-w-xl mx-auto leading-relaxed">
        Every file — adapter weights, GGUF, tokenizer, and the full model card — is public on <a href="https://huggingface.co/pointbreaklab/knot-ai" target="_blank" rel="noopener" class="text-accent hover:underline">Hugging Face</a>.
      </p>
    </div>
  </section>

  <!-- ── 04 GET IT ────────────────────────────────────────────────────────── -->
  <section id="get" class="relative py-32 px-6 max-w-3xl mx-auto">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[70%] h-72 bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div class="relative">
      <div class="section-reveal text-center mb-12">
        <SectionEyebrow num="04" label="GET IT" />
        <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">Run it in one line.</h2>
        <p class="text-secondary max-w-xl mx-auto leading-relaxed">
          Open weights on Ollama and Hugging Face. Point it at a staged diff and get a commit message back.
        </p>
      </div>

      <div class="section-reveal space-y-4">
        {[
          { label: 'OLLAMA', code: 'ollama run pointbreaklab/knot-ai "$(git diff --staged)"' },
          { label: 'LLAMA.CPP · BASE + THIS LORA', code: 'llama-server --model qwen2.5-coder-7b-instruct-q4_k_m.gguf \\\n             --lora knot-ai-lora-f16.gguf' },
        ].map(({ label, code }) => (
          <div class="rounded-2xl bg-bg border border-border overflow-hidden">
            <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
              <div class="w-3 h-3 rounded-full bg-error/70"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
              <div class="w-3 h-3 rounded-full bg-accent/70"></div>
              <span class="ml-2 text-hint text-xs font-mono">{label}</span>
            </div>
            <pre class="p-5 text-xs md:text-sm font-mono text-primary/90 overflow-x-auto"><code>{code}</code></pre>
          </div>
        ))}
      </div>

      <div class="section-reveal flex flex-col sm:flex-row items-center justify-center gap-4 mt-10">
        <a href="https://ollama.com/pointbreaklab/knot-ai" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent text-bg font-bold text-sm hover:bg-white transition-all hover:scale-105">
          🦙 Ollama
        </a>
        <a href="https://huggingface.co/pointbreaklab/knot-ai" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-border text-secondary text-sm font-mono hover:border-accent hover:text-primary transition-all">
          🤗 huggingface.co/pointbreaklab/knot-ai
        </a>
      </div>

      <p class="section-reveal text-hint text-[11px] text-center mt-10 max-w-xl mx-auto leading-relaxed">
        Knot AI is the on-device model inside <a href="/knot/" class="text-accent hover:underline">Knot</a>, PointBreakLab's peer-to-peer version control system — where it writes every commit message hands-free.
      </p>
    </div>
  </section>

  <Footer />
</Base>
