---
import Base           from '../../layouts/Base.astro';
import Nav            from '../../components/Nav.astro';
import FeatureBlock   from '../../components/FeatureBlock.astro';
import DownloadButton from '../../components/DownloadButton.astro';
import Footer         from '../../components/Footer.astro';
import HeartArchitectureDiagram from '../../components/HeartArchitectureDiagram.astro';
import SectionEyebrow from '../../components/SectionEyebrow.astro';
import '../../styles/global.css';

const screenshots = [
  { src: '/screenshots/heart/flutter_01.png', caption: 'Live HR · zones · real-time burn rate',       alt: 'Home screen showing 104 bpm live heart rate with zone 2 indicator' },
  { src: '/screenshots/heart/flutter_02.png', caption: 'Sleep stages · recovery ring · strain',        alt: 'Home screen showing sleep stage breakdown, recovery ring and recent sessions' },
  { src: '/screenshots/heart/flutter_08.png', caption: 'Insights · 24h wear · active energy sparkline', alt: 'Insights tab showing 15h 28m wear time and active energy sparkline' },
  { src: '/screenshots/heart/flutter_05.png', caption: 'Sleep trends · 7-night duration chart',        alt: 'Trends sleep tab showing 7-day sleep duration chart' },
  { src: '/screenshots/heart/flutter_11.png', caption: 'Sessions · GPS routes · activity history',     alt: 'Trends sessions tab showing GPS route map of a run in Würzburg' },
];
---

<Base
  title="Heart · Local-first wellness app for Bluetooth heart-rate bands"
  description="A wellness app for Bluetooth heart-rate bands. Tracks HR, HRV, sleep stages, recovery, strain — entirely on your device. No account, no cloud, no subscription. Pairs with the Coospo HW9 (worn on the chest or arm) and any standard BLE chest strap."
>
  <Nav />

  <!-- ── HERO (Heart-specific, slim) ──────────────────────────────────────── -->
  <section class="relative pt-32 pb-20 px-6 overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-[28rem] bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div aria-hidden="true" class="absolute top-1/3 right-0 w-72 h-72 bg-blue-500/[0.04] blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/30 bg-accent/5 text-accent text-xs font-mono tracking-wider mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        HEART · LOCAL-FIRST WELLNESS
      </div>

      <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6">
        <span class="text-primary">Your heart,</span><br/>
        <span class="text-gradient">on your device.</span>
      </h1>

      <p class="text-lg text-secondary font-light max-w-xl mx-auto leading-relaxed mb-3">
        A wellness app for Bluetooth heart-rate bands. Tracks HR, HRV, sleep, recovery, and strain — entirely on your device. No account, no cloud, no subscription.
      </p>
      <p class="text-sm text-hint font-mono mb-10">
        Free · on-device · auditable.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#download"
          class="px-8 py-3.5 rounded-xl bg-accent text-bg font-bold text-sm hover:bg-white transition-all hover:scale-105 hover:shadow-[0_0_32px_rgba(0,212,170,0.4)]"
        >
          Download for Android
        </a>
        <a
          href="#architecture"
          class="px-8 py-3.5 rounded-xl border border-border text-secondary text-sm hover:border-accent hover:text-primary transition-all"
        >
          See the algorithms
        </a>
      </div>
    </div>
  </section>

  <!-- ── 01 FEATURES ──────────────────────────────────────────────────────── -->
  <section id="features" class="relative py-28 px-6 max-w-7xl mx-auto">
    <div aria-hidden="true" class="absolute top-0 left-1/4 w-[40%] h-72 bg-accent/[0.06] blur-3xl pointer-events-none"></div>

    <div class="section-reveal text-center mb-16">
      <SectionEyebrow num="01" label="FEATURES" />
      <h2 class="text-3xl md:text-5xl font-black text-primary mb-4">What it does</h2>
      <p class="text-secondary max-w-xl mx-auto leading-relaxed">
        Eight features. All on-device. No subscription, no cloud, no compromise.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-24">
      <FeatureBlock
        icon="❤️"
        title="Live HR + HRV"
        description="Continuous heart rate, zones, and RMSSD-based heart-rate variability — computed directly from R–R intervals using the 1996 ESC/NASPE standard."
      />
      <FeatureBlock
        icon="🌙"
        title="Four-stage sleep"
        description="Awake, light, deep, REM — derived from overnight HR with a prior-calibrated stager. Avg HR, min HR, and overnight HRV per night."
      />
      <FeatureBlock
        icon="🔋"
        title="Recovery & Strain"
        description="WHOOP-inspired recovery score — HRV percentile against your personal 30-day baseline. Zone-weighted strain. Both derived from published methodology, not black boxes."
      />
      <FeatureBlock
        icon="📊"
        title="Insights with history"
        description="Pick any past day, custom 24h windows, or 8 AM → 8 AM physiological days. Wear time, energy, sessions with GPS path, sleep snapshot, on-device coach."
      />
      <FeatureBlock
        icon="🧠"
        title="On-device intelligence"
        description="A readiness forecast that estimates tomorrow's overnight HRV from today's signal, rhythm-anomaly detection on beat-to-beat variability, and a personal-baseline percentile system over a 30-day rolling window."
      />
      <FeatureBlock
        icon="🏋️"
        title="Post-workout analysis"
        description="End a session and get an instant full summary — HR zone breakdown, peak and avg BPM, active calories, a side-by-side compare to your last session of the same type, and an estimated overnight HRV impact."
      />
      <FeatureBlock
        icon="📍"
        title="Gym auto-detection"
        description="Pin your gym's location once. Pick a detection radius (100–500 m). Heart offers to start a session automatically after 10 minutes of dwell — nothing leaves your device, no map service, no movement history."
      />
      <FeatureBlock
        icon="🚫"
        title="No account, no cloud"
        description="Everything stays on your device — sample data, scores, sleep history. One-tap JSON export for migration. One-tap delete-everything."
      />
    </div>

    <!-- How it works -->
    <div class="section-reveal mb-20">
      <p class="text-accent text-xs font-mono tracking-widest mb-3 text-center">HOW IT WORKS</p>
      <h3 class="text-2xl md:text-3xl font-black text-primary mb-4 text-center">Pairs with what you already own.</h3>
      <p class="text-secondary max-w-2xl mx-auto mb-12 text-center leading-relaxed">
        Heart speaks the standard BLE Heart Rate Service (UUID 0x180D). Works with the Coospo HW9 — worn on the chest or arm — and most modern chest straps.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '01', title: 'Pair your band',  body: 'Open Settings → Devices, scan, tap your HW9 (or any BLE HRS strap). One-time approval — no account, no QR, no cloud handshake.' },
          { step: '02', title: 'Wear it 24/7',    body: 'iOS state restoration and an Android foreground service keep the connection alive overnight, even when the phone is in your pocket.' },
          { step: '03', title: 'Get insights',    body: 'Recovery, strain, sleep stages, and on-device Coach observations every morning. Self-validate with a one-tap sleep diary.' },
        ].map(({ step, title, body }) => (
          <div class="section-reveal relative pl-8 border-l border-border hover:border-accent/40 transition-colors">
            <span class="absolute -left-px top-0 w-0.5 h-8 bg-accent"></span>
            <p class="text-accent font-mono text-xs mb-2">{step}</p>
            <h4 class="text-lg font-bold text-primary mb-2">{title}</h4>
            <p class="text-secondary text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Hardware support -->
    <div class="section-reveal">
      <p class="text-accent text-xs font-mono tracking-widest mb-3 text-center">HARDWARE</p>
      <h3 class="text-2xl md:text-3xl font-black text-primary mb-12 text-center">Pairs with the band you already own.</h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { icon: '🟢', label: 'PRIMARY',  title: 'Coospo HW9',   body: 'A versatile band — worn on the chest, upper arm, or forearm. Full feature support: live HR, RR-interval HRV, battery percentage reporting. Heart was developed and tested with this band.' },
          { icon: '🔵', label: 'STANDARD', title: 'Any BLE strap', body: 'Polar H10, Wahoo TICKR, Garmin HRM-Dual — anything that speaks Heart Rate Service 0x180D + Heart Rate Measurement 0x2A37.' },
          { icon: '🟡', label: 'OPTICAL',  title: 'Wrist sensors', body: 'Live HR works on optical wrist HR straps, but RR-interval availability depends on the device — HRV will be coarser than from a chest strap.' },
        ].map(({ icon, label, title, body }) => (
          <div class="p-6 rounded-2xl bg-surface border border-border hover:border-accent/30 transition-colors text-center group">
            <div class="text-4xl mb-4">{icon}</div>
            <div class="inline-block px-2 py-0.5 rounded bg-accent/10 text-accent text-xs font-mono mb-3">{label}</div>
            <h4 class="text-base font-bold text-primary mb-2">{title}</h4>
            <p class="text-secondary text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>

      <!-- The band is just a sensor -->
      <div class="section-reveal mt-20">
        <p class="text-accent text-xs font-mono tracking-widest mb-3 text-center">THE BAND IS JUST A SENSOR</p>
        <h3 class="text-2xl md:text-3xl font-black text-primary mb-10 text-center">Your band broadcasts.<br/>Heart listens.</h3>

        <div class="max-w-2xl mx-auto space-y-4 mb-14">
          <p class="text-secondary text-sm leading-relaxed">
            The Coospo HW9 is a dumb sensor <span class="text-hint italic">(a device that only broadcasts raw data — no onboard processing, no memory, no intelligence of its own)</span>. Every heartbeat it detects an R-wave, computes a beat interval, and broadcasts two values — BPM and milliseconds since the last beat — over a short-range Bluetooth link. Then it forgets. It doesn't know your name, what day it is, or whether last night was good sleep or bad.
          </p>
          <p class="text-secondary text-sm leading-relaxed">
            The official Coospo app catches that broadcast. Shows you 104 bpm. It was built for bike computers — pairing sensors to head units, syncing ride logs, tracking kilometres. Using it for daily wellness is like using a speedometer to track your resting heart rate.
          </p>
          <p class="text-secondary text-sm leading-relaxed">
            Heart catches the same broadcast — and doesn't let go.
          </p>
        </div>

        <!-- comparison panel -->
        <div class="font-mono text-xs rounded-2xl bg-bg border border-border overflow-hidden">
          <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
            <div class="w-3 h-3 rounded-full bg-error/70"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-accent/70"></div>
            <span class="ml-2 text-hint text-xs">same-signal.txt</span>
          </div>
          <div class="p-5 md:p-6 overflow-x-auto">
            <!-- header row -->
            <div class="flex gap-2 mb-3 pb-3 border-b border-border">
              <span class="text-hint shrink-0" style="width:220px"></span>
              <span class="text-hint shrink-0 text-center" style="width:110px">COOSPO APP</span>
              <span class="text-accent shrink-0 text-center" style="width:240px">HEART</span>
            </div>
            <!-- rows -->
            {[
              { label: 'Shows live BPM',         coospo: true,  heart: true,  note: '' },
              { label: 'Stores every beat',       coospo: false, heart: true,  note: 'on-device, sandboxed' },
              { label: 'HRV (RMSSD)',             coospo: false, heart: true,  note: 'from R–R intervals' },
              { label: '4-stage sleep',           coospo: false, heart: true,  note: 'rule-based + calibrated' },
              { label: 'Recovery score',          coospo: false, heart: true,  note: 'vs your 30-day baseline' },
              { label: 'Rhythm hints',            coospo: false, heart: true,  note: 'beat-skip rate anomaly detection' },
              { label: 'GPS sessions',            coospo: false, heart: true,  note: 'route maps + calories' },
              { label: 'Post-workout analysis',   coospo: false, heart: true,  note: 'zones · compare · recovery impact' },
              { label: 'Gym auto-detection',      coospo: false, heart: true,  note: 'GPS geofence · on-device only' },
              { label: 'Insights & trends',       coospo: false, heart: true,  note: '24h window deep-dive' },
              null,
              { label: 'Needs an account',        coospo: true,  heart: false, note: '' },
              { label: 'Cloud sync',              coospo: true,  heart: false, note: 'everything stays local' },
              { label: 'Subscription',            coospo: false, heart: false, note: 'free' },
            ].map((row) => row === null
              ? <div class="border-t border-border my-2"></div>
              : (
              <div class="flex gap-2 items-baseline py-1.5">
                <span class="text-hint shrink-0" style="width:220px">{row.label}</span>
                <span class="shrink-0 text-center" style="width:110px">
                  {row.coospo
                    ? <span class="text-primary/50">✓</span>
                    : <span class="text-hint/40">—</span>
                  }
                </span>
                <span class="shrink-0 text-center" style="width:48px">
                  {row.heart
                    ? <span class="text-accent">✓</span>
                    : <span class="text-hint/40">—</span>
                  }
                </span>
                {row.note && <span class="text-hint pl-2">{row.note}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── SCREENSHOTS ───────────────────────────────────────────────────────── -->
  <section class="relative py-24 px-6 overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 right-1/4 w-[40%] h-64 bg-accent/[0.05] blur-3xl pointer-events-none"></div>

    <div class="max-w-lg mx-auto">
      <div class="text-center mb-14">
        <p class="text-accent text-xs font-mono tracking-widest mb-3">IN THE APP</p>
        <h2 class="text-2xl md:text-3xl font-black text-primary mb-3">A look inside.</h2>
        <p class="text-secondary text-sm max-w-sm mx-auto leading-relaxed">
          Five screens from the daily loop — live monitoring, sleep review, insights, trends, and GPS sessions.
        </p>
      </div>

      <div id="heart-carousel" class="flex flex-col items-center select-none">

        <!-- phone frame -->
        <div class="relative" style="width:260px">
          <!-- volume buttons -->
          <div class="absolute" style="left:-3px;top:88px;width:3px;height:28px;background:#2a2a35;border-radius:2px 0 0 2px"></div>
          <div class="absolute" style="left:-3px;top:128px;width:3px;height:48px;background:#2a2a35;border-radius:2px 0 0 2px"></div>
          <!-- power button -->
          <div class="absolute" style="right:-3px;top:108px;width:3px;height:36px;background:#2a2a35;border-radius:0 2px 2px 0"></div>

          <div class="rounded-[38px] border-2 border-[#23232a] bg-[#0e0e11] p-2.5"
               style="box-shadow:0 32px 80px rgba(0,0,0,0.8),0 0 0 1px rgba(255,255,255,0.025)">
            <div class="rounded-[30px] overflow-hidden" style="aspect-ratio:9/19.4">
              <div class="relative w-full h-full">
                {screenshots.map((s, i) => (
                  <img
                    src={s.src}
                    alt={s.alt}
                    width="236"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    class="absolute inset-0 w-full h-full object-cover"
                    style={`opacity:${i === 0 ? 1 : 0};z-index:${i === 0 ? 1 : 0};transition:opacity 0.45s ease`}
                    data-heart-slide={i}
                  />
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- caption -->
        <div class="relative mt-6 w-full" style="height:18px">
          {screenshots.map((s, i) => (
            <p
              class="absolute inset-0 flex items-center justify-center text-xs font-mono text-hint"
              style={`opacity:${i === 0 ? 1 : 0};transition:opacity 0.35s ease`}
              data-heart-caption={i}
            >
              {s.caption}
            </p>
          ))}
        </div>

        <!-- dots -->
        <div class="flex gap-3 mt-5">
          {screenshots.map((_, i) => (
            <button
              aria-label={`Screenshot ${i + 1} of ${screenshots.length}`}
              data-heart-dot={i}
              style={i === 0
                ? 'width:8px;height:8px;border-radius:50%;background:#00d4aa;transform:scale(1.3);transition:all 0.3s ease;border:none;cursor:pointer;padding:0'
                : 'width:8px;height:8px;border-radius:50%;background:#737373;transform:scale(1);transition:all 0.3s ease;border:none;cursor:pointer;padding:0'}
            />
          ))}
        </div>

      </div>
    </div>

    <script is:inline>
    (function () {
      var slides   = document.querySelectorAll('[data-heart-slide]');
      var captions = document.querySelectorAll('[data-heart-caption]');
      var dots     = document.querySelectorAll('[data-heart-dot]');
      var n        = slides.length;
      var cur      = 0;
      var timer    = null;
      var reduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function show(i) {
        [slides, captions].forEach(function (col) {
          col[cur].style.opacity = '0';
          col[cur].style.zIndex  = '0';
          col[i].style.opacity   = '1';
          col[i].style.zIndex    = '1';
        });
        dots[cur].style.background = '#737373';
        dots[cur].style.transform  = 'scale(1)';
        dots[i].style.background   = '#00d4aa';
        dots[i].style.transform    = 'scale(1.3)';
        cur = i;
      }

      function advance() { show((cur + 1) % n); }

      function start() {
        if (reduced || timer) return;
        timer = setInterval(advance, 4000);
      }

      function stop() {
        clearInterval(timer);
        timer = null;
      }

      dots.forEach(function (dot, i) {
        dot.addEventListener('click', function () { stop(); show(i); start(); });
      });

      var carousel = document.getElementById('heart-carousel');
      carousel.addEventListener('mouseenter', stop);
      carousel.addEventListener('mouseleave', start);

      start();
    })();
    </script>
  </section>

  <!-- ── 02 ARCHITECTURE ──────────────────────────────────────────────────── -->
  <section id="architecture" class="relative py-32 px-6 bg-surface border-y border-border overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-72 bg-accent/[0.08] blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">

      <div class="section-reveal text-center mb-16">
        <SectionEyebrow num="02" label="ARCHITECTURE" />
        <h2 class="text-3xl md:text-5xl font-light text-primary mb-4 tracking-tight">A time-series engine,<br/>not an AI black box.</h2>
        <p class="text-secondary max-w-2xl mx-auto leading-relaxed">
          Heart ingests raw R–R intervals off a BLE characteristic, runs classical signal processing on a 300-sample sliding window, and produces auditable scores. No neural network. No model weights. No remote inference. Every formula traces to a published paper and every constant is documented in source.
        </p>
      </div>

      <!-- device-flow diagram (kept as orientation) -->
      <div class="section-reveal mb-20">
        <HeartArchitectureDiagram />
      </div>

      <!-- ── PIPELINE + MATH · collapsible ──────────────────────────────── -->
      <details class="group section-reveal rounded-2xl border border-border overflow-hidden mb-20">
        <summary class="flex items-center justify-between gap-4 px-5 py-3.5 bg-surface cursor-pointer list-none [&::-webkit-details-marker]:hidden hover:bg-surface/60 transition-colors">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-error/70"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-accent/70"></div>
            <span class="ml-2 text-hint text-xs font-mono">pipeline-and-math.txt</span>
          </div>
          <div class="flex items-center gap-2 font-mono text-xs select-none">
            <span class="text-secondary">Pipeline &amp; Math — technical detail</span>
            <span class="text-accent group-open:hidden">▶</span>
            <span class="text-accent hidden group-open:inline">▼</span>
          </div>
        </summary>

        <div class="border-t border-border bg-bg">

          <!-- THE PIPELINE -->
          <div class="px-6 pt-8 pb-6">
            <p class="text-accent text-xs font-mono tracking-widest mb-8 text-center">THE PIPELINE · RAW BYTES → RECOVERY SCORE</p>
            <div class="max-w-2xl mx-auto">
              {[
                {
                  tag:    'STEP 1 · BLE INGEST',
                  title:  'BLE 0x2A37 notify frame',
                  detail: 'flags[0] | bpm[1] | RR_low[2] | RR_high[3] …   ·   ~1 notify / sec',
                  sub:    'bit1(flags) == 1  →  RR values present in frame',
                  accent: true,
                },
                {
                  tag:    'STEP 2 · PARSE',
                  title:  'RR interval extractor',
                  detail: 'uint16_le(frame[i], frame[i+1])  /  1024.0  ×  1000  →  ms',
                  sub:    'physiological gate: discard RR outside [300 ms, 2000 ms]',
                  accent: true,
                },
                {
                  tag:    'STEP 3 · PERSIST',
                  title:  'JSONL log  ·  heart_samples/YYYY-MM-DD.jsonl',
                  detail: '{"ts_ms": 1715608800000, "bpm": 72, "rr_ms": [812, 819, 808]}',
                  sub:    'appended live · sandboxed app storage · OS-encrypted at rest',
                  accent: false,
                },
                {
                  tag:    'STEP 4 · HRV',
                  title:  '300-sample ring buffer  →  RMSSD',
                  detail: 'RMSSD = √( Σ(RRᵢ₊₁ − RRᵢ)²  /  (N − 1) )   [N ≥ 4]',
                  sub:    'ESC/NASPE Task Force · Eur. Heart J. 17:354–381 · 1996',
                  accent: true,
                },
                {
                  tag:    'STEP 5 · SLEEP STAGING',
                  title:  'Deterministic four-stage sleep classifier  ·  5-min HR buckets',
                  detail: 'mean_bpm < baseline + 8  →  sleep candidate',
                  sub:    'onset gate 0.70  ·  stability σ < 6 bpm  ·  4 stages: awake / light / deep / REM  ·  deterministic heuristics chosen over on-device ML — continuous tflite inference overnight would drain both phone and band battery in hours',
                  accent: false,
                },
                {
                  tag:    'STEP 6 · BASELINE',
                  title:  'OvernightBaselineComputer  ·  30-day rolling window',
                  detail: 'RMSSD_array[−30 … −1]  →  percentile rank of last night',
                  sub:    'recovery = floor( rank × 100 )   ·   strain = zone-weighted effort Σ',
                  accent: true,
                },
              ].map((step, i, arr) => (
                <div>
                  <div class={`rounded-xl border p-4 font-mono text-xs ${step.accent ? 'border-accent/40 bg-bg' : 'border-border bg-bg/60'}`}>
                    <p class="text-hint tracking-widest mb-1.5">{step.tag}</p>
                    <p class={`text-sm mb-1 ${step.accent ? 'text-accent' : 'text-primary/80'}`}>{step.title}</p>
                    <p class="text-primary/60 leading-relaxed">{step.detail}</p>
                    <p class="text-hint mt-1 leading-relaxed">{step.sub}</p>
                  </div>
                  {i < arr.length - 1 && (
                    <div class="flex justify-center py-3 text-accent/60 text-lg select-none">↓</div>
                  )}
                </div>
              ))}
            </div>
          </div>

          <!-- divider -->
          <div class="border-t border-border mx-6"></div>

          <!-- THE MATH -->
          <div class="px-6 pt-8 pb-8">
            <p class="text-accent text-xs font-mono tracking-widest mb-8 text-center">THE MATH · RMSSD</p>
            <div class="rounded-xl bg-bg border border-border overflow-hidden">
              <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface">
                <div class="w-3 h-3 rounded-full bg-error/70"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
